---
interface Props {
    locale?: 'en' | 'pt';
}

const { locale = 'en' } = Astro.props;

const isPortuguese = locale === 'pt';
const baseUrl = isPortuguese ? '/pt' : '';
---

<footer class="footer">
    <div class="footer-content">
        <div class="footer-section">
            <h4>{isPortuguese ? 'Sobre' : 'About'}</h4>
            <p class="footer-description">
                {isPortuguese
                    ? 'Ajudo PMEs portuguesas a poupar tempo e dinheiro através de redesenho de workflows e soluções internas de IA.'
                    : 'Helping Portuguese SMEs save time and money through AI-powered workflow redesign and internal solutions.'}
            </p>
            <a href="https://www.linkedin.com/in/lumadeira" class="footer-social" target="_blank" rel="noopener" aria-label="LinkedIn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6.94 5.00002C6.93974 5.53046 6.72877 6.03906 6.35351 6.41394C5.97825 6.78883 5.46944 6.99929 4.939 6.99902C4.40857 6.99876 3.89997 6.78779 3.52508 6.41253C3.1502 6.03727 2.93974 5.52846 2.94 4.99802C2.94027 4.46759 3.15124 3.95899 3.5265 3.5841C3.90176 3.20922 4.41057 2.99876 4.941 2.99902C5.47144 2.99929 5.98004 3.21026 6.35492 3.58552C6.72981 3.96078 6.94027 4.46959 6.94 5.00002ZM7 8.48002H3V21H7V8.48002ZM13.32 8.48002H9.34V21H13.28V14.43C13.28 10.77 18.05 10.43 18.05 14.43V21H22V13.07C22 6.90002 14.94 7.13002 13.28 10.16L13.32 8.48002Z" fill="currentColor"/>
                </svg>
            </a>
        </div>

        <div class="footer-section">
            <h4>{isPortuguese ? 'Links Rápidos' : 'Quick Links'}</h4>
            <ul class="footer-links">
                <li><a href={`${baseUrl}/`}>{isPortuguese ? 'Início' : 'Home'}</a></li>
                <li><a href={`${baseUrl === '' ? '/about' : '/pt/sobre'}`}>{isPortuguese ? 'Sobre' : 'About'}</a></li>
                <li><a href={`${baseUrl === '' ? '/services' : '/pt/servicos'}`}>{isPortuguese ? 'Serviços' : 'Services'}</a></li>
                <li><a href={`${baseUrl}/#contact`}>{isPortuguese ? 'Contacto' : 'Contact'}</a></li>
            </ul>
        </div>
    </div>

    <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Luís Madeira. {isPortuguese ? 'Todos os direitos reservados.' : 'All rights reserved.'}</p>
    </div>
</footer>

<style>
/* Footer uses the explicit dark surface tokens for contrast inside the
   otherwise light site theme. */
.footer {
    background-color: var(--ink-surface, #0d0d0d);
    color: var(--on-ink, #ededea);
    border-top: 1px solid var(--border-ink, #2a2a2a);
    padding: 60px 108px 24px;
}

.footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
}

.footer-section h4 {
    font-size: 16px;
    font-weight: 600;
    color: var(--accent, #d3e97a);
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.footer-description {
    font-size: 14px;
    line-height: 1.6;
    opacity: 0.75;
    max-width: 300px;
}

.footer-social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    margin-top: 20px;
    border: 1px solid var(--accent, #d3e97a);
    border-radius: 50%;
    color: var(--accent, #d3e97a);
    transition: background-color 0.3s ease, color 0.3s ease;
}

.footer-social:hover {
    background-color: var(--accent, #d3e97a);
    color: var(--ink-surface, #0d0d0d);
}

.footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.footer-links a {
    color: var(--on-ink, #ededea);
    text-decoration: none;
    font-size: 14px;
    opacity: 0.75;
    transition: opacity 0.3s ease, color 0.3s ease;
}

.footer-links a:hover {
    opacity: 1;
    color: var(--accent, #d3e97a);
}

.footer-bottom {
    border-top: 1px solid var(--border-ink, #2a2a2a);
    padding-top: 24px;
    text-align: center;
}

.footer-bottom p {
    font-size: 13px;
    opacity: 0.6;
    margin: 0;
}

/* Responsive Design */
@media (max-width: 1024px) {
    .footer {
        padding: 48px 32px 24px;
    }

    .footer-content {
        grid-template-columns: repeat(2, 1fr);
        gap: 32px;
    }
}

@media (max-width: 768px) {
    .footer {
        padding: 40px 16px 20px;
    }

    .footer-content {
        grid-template-columns: 1fr;
        gap: 32px;
    }

    .footer-description {
        max-width: 100%;
    }
}
</style>
