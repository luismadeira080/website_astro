---
import SEO from "../components/SEO.astro";
import Schema from "../components/Schema.astro";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import Footer from "../components/Footer.astro";
import '../styles/tokens.css';
---

<!doctype html>
<html lang="en">
    <head>
        <!-- Google Tag Manager -->
        <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-WHTQCRZ4');</script>
        <!-- End Google Tag Manager -->
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="/favicon-32x32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href="/favicon-16x16.png"
        />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/apple-touch-icon.png"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />

        <!-- SEO Meta Tags -->
        <SEO
            title="AI Consulting"
            description="Ongoing AI partner for SMEs. I map highest-ROI opportunities, build reliable and auditable AI processes, and stay with you as your operations evolve."
            locale="en"
        />

        <!-- Structured Data -->
        <Schema type="Organization" />
    </head>
    <body>
        <!-- Google Tag Manager (noscript) -->
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WHTQCRZ4"
        height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
        <!-- End Google Tag Manager (noscript) -->
        <!-- Navigation -->
        <nav class="navigation">
            <a href="/" class="logo">luís madeira</a>
            <div class="nav-links">
                <a href="/services">Services</a>
                <a href="/about">About</a>
                <a href="/#contact">Contact</a>
                <LanguageSwitcher currentPath="/services" />
            </div>
            <div class="mobile-menu-toggle">
                <span></span>
                <span></span>
            </div>
        </nav>

        <!-- Hero Section -->
        <section class="page-hero">
            <div class="page-hero-content">
                <h1>CUSTOM SOLUTIONS. REAL RESULTS.</h1>
                <p class="page-hero-subtitle">
                    I find where your business loses time and money, build internal solutions that fix it, and stay with you as things evolve.
                </p>
            </div>
        </section>

        <!-- Main Content -->
        <section class="content-section">
            <div class="content-wrapper">
                <div class="content-main">

                    <!-- Consulting & Implementation intro -->
                    <div class="engagement-intro">
                        <h2>Consulting & Implementation</h2>
                        <p>Two ways to work together, depending on where you're starting from.</p>
                        <div class="engagement-paths">
                            <a href="#diagnostic" class="engagement-path">
                                <h3>Not sure where the opportunity is?</h3>
                                <p>Start with a Diagnostic.</p>
                            </a>
                            <a href="#implementation" class="engagement-path">
                                <h3>Already know what you need?</h3>
                                <p>Go straight to Implementation.</p>
                            </a>
                        </div>
                    </div>

                    <!-- Service Layer 1: Audit -->
                    <div class="service-layer" id="diagnostic">
                        <div class="service-layer-label">Diagnostic</div>
                        <h2>Operations Audit</h2>
                        <p class="service-layer-price">Fixed price. Low risk. Clear output.</p>
                        <p>
                            Before building anything, I map your operations end-to-end. How work actually moves through your business, where data lives, where time gets lost, and what's holding growth back.
                        </p>
                        <p>
                            The output is a prioritized roadmap: the highest-ROI opportunities specific to your business, what each one involves, what impact to expect, and how we'll measure it. You know exactly where your investment goes before anything gets built.
                        </p>
                        <p>This is the right starting point if you're not yet sure where the opportunity is. It's low risk, and it means every decision after is grounded in your real operations, not assumptions. If you already know what you need, you can go straight to Implementation below.</p>
                    </div>

                    <!-- Service Layer 2: Implementation -->
                    <div class="service-layer" id="implementation">
                        <div class="service-layer-label">Build</div>
                        <h2>Implementation</h2>
                        <p>Two delivery models depending on what you need. This works equally well whether you've just finished a Diagnostic or you already know exactly what needs to be built.</p>

                        <div class="impl-grid">
                            <div class="impl-card">
                                <h3>Custom Solutions</h3>
                                <p class="impl-pricing">Time &amp; materials</p>
                                <p>For complex, bespoke needs: cross-system integration, data consolidation across fragmented sources, process redesign that touches multiple teams. Scoped and priced based on time and value delivered.</p>
                                <ul>
                                    <li>Multi-system workflow automation</li>
                                    <li>Data consolidation from scattered sources</li>
                                    <li>Complex process redesign</li>
                                    <li>Custom AI integrations</li>
                                </ul>
                            </div>
                            <div class="impl-card">
                                <h3>Productized Solutions</h3>
                                <p class="impl-pricing">Fixed price</p>
                                <p>Repeatable patterns I've already templated and refined. Fast deployment, predictable cost. Right for common operational pain points where you need results quickly.</p>
                                <ul>
                                    <li>Invoice and document processing</li>
                                    <li>CRM enrichment and data cleanup</li>
                                    <li>Automated report generation</li>
                                    <li>Document classification and routing</li>
                                </ul>
                            </div>
                        </div>

                        <p class="impl-note">In both cases, your team learns how it works as we build it. No black boxes, no dependency on me to keep the lights on.</p>
                    </div>

                    <!-- Optional: Retainer -->
                    <div class="service-layer">
                        <div class="service-layer-label">Optional</div>
                        <h2>Ongoing Retainer</h2>
                        <p class="service-layer-price">Recurring, only if you want it. Evolves with your business.</p>
                        <p>
                            Some clients want ongoing support after launch: monitoring, optimization, and new requests handled without restarting from scratch each time. The retainer exists for exactly that. It's optional, not a required next step after Implementation.
                        </p>
                        <ul>
                            <li>Monitoring and proactive maintenance of live systems</li>
                            <li>Ongoing optimization as you gather real-world data</li>
                            <li>New automation requests handled within the retainer</li>
                            <li>Priority support when something breaks</li>
                        </ul>
                    </div>

                    <!-- Business Areas -->
                    <h2>Where I Work</h2>
                    <p>Organized by business function, not industry. The same operational pain shows up across sectors.</p>

                    <div class="areas-grid">
                        <div class="area-item">
                            <h3>Stock & Procurement</h3>
                            <ul>
                                <li>Real visibility into what's actually in stock, not five spreadsheets that don't agree</li>
                                <li>Reorder decisions based on actual sales data, not whoever remembers to check</li>
                                <li>Purchasing pulled straight from what's already in your ERP</li>
                            </ul>
                        </div>
                        <div class="area-item">
                            <h3>Sales & Commercial</h3>
                            <ul>
                                <li>Lead qualification and follow-up automation</li>
                                <li>Pipeline data kept clean and up to date</li>
                                <li>Proposal and quote generation</li>
                                <li>Full visibility at every stage of the funnel</li>
                            </ul>
                        </div>
                        <div class="area-item">
                            <h3>Operations & Logistics</h3>
                            <ul>
                                <li>Fewer manual handoffs between teams</li>
                                <li>Exception handling that doesn't rely on one person</li>
                                <li>Smoother coordination across locations and partners</li>
                            </ul>
                        </div>
                        <div class="area-item">
                            <h3>Admin & Back Office</h3>
                            <ul>
                                <li>Invoice processing without manual effort</li>
                                <li>Document classification and routing</li>
                                <li>Contract review and extraction</li>
                                <li>Compliance and filing automation</li>
                            </ul>
                        </div>
                        <div class="area-item">
                            <h3>Customer Service</h3>
                            <ul>
                                <li>Faster response times across channels</li>
                                <li>Consistent answers to common questions</li>
                                <li>Ticket triage and routing</li>
                                <li>Less repetitive work for your support team</li>
                            </ul>
                        </div>
                        <div class="area-item">
                            <h3>Reporting & Decisions</h3>
                            <ul>
                                <li>Real-time dashboards instead of month-end surprises</li>
                                <li>Data consolidated from every source automatically</li>
                                <li>KPI monitoring with alerts when something's off</li>
                                <li>Management visibility without chasing people for numbers</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Flagship Spotlight -->
                    <div class="flagship-spotlight">
                        <div class="service-layer-label">Proven pattern</div>
                        <h3>A closer look: Stock & Procurement</h3>
                        <p>Many businesses run stock control across multiple spreadsheets that rarely agree with each other, with purchasing decisions depending on whoever happens to check the numbers at a given moment. We recognize this as one of the most recurring operational patterns among the businesses we work with.</p>
                        <p>To address it, we build a solution that integrates real movement data, often already sitting in the company's ERP, into a single, unified view of stock and sales, replacing manual checks with a data-driven automatic reorder system.</p>
                        <p class="flagship-spotlight-label">What this delivers:</p>
                        <ul>
                            <li>A single, consolidated view of stock, not multiple spreadsheets</li>
                            <li>Demand forecasting based on real sales data, not guesswork</li>
                            <li>Automated reorder points, connected to the company's ERP</li>
                            <li>A solution already tested and running in a real deployment</li>
                        </ul>
                    </div>

                    <!-- Training note -->
                    <div class="training-note">
                        <strong>Team enablement is part of every project.</strong> I build systems your team understands and can work with, not black boxes they depend on me to maintain. For businesses that want to go further, standalone workshops are available as a separate engagement.
                    </div>

                </div>

                <div class="content-sidebar">
                    <div class="sidebar-card">
                        <h3>Not sure where to start?</h3>
                        <p>The Operations Audit is the right first step. You'll get a clear picture of where the opportunities are before committing to anything.</p>
                    </div>

                    <div class="sidebar-card">
                        <h3>How I approach it</h3>
                        <ul>
                            <li>Business impact first, tools second</li>
                            <li>Start where it moves the needle most</li>
                            <li>No black boxes: your team understands what's running</li>
                            <li>Measure everything so you know what's working</li>
                        </ul>
                    </div>

                    <div class="sidebar-card cta-card">
                        <h3>Let's talk</h3>
                        <p>Tell me what's slowing you down. I'll tell you what I can do about it.</p>
                        <a href="/ai-contact" class="sidebar-cta">Get in touch</a>
                    </div>
                </div>
            </div>
        </section>

        <script>
            // Mobile Menu Toggle
            const mobileMenuToggle = document.querySelector(
                ".mobile-menu-toggle",
            );
            const navLinks = document.querySelector(".nav-links");

            if (mobileMenuToggle) {
                mobileMenuToggle.addEventListener("click", () => {
                    mobileMenuToggle.classList.toggle("active");
                    navLinks.classList.toggle("active");
                });

                // Close menu when clicking on a link
                const links = navLinks.querySelectorAll("a");
                links.forEach((link) => {
                    link.addEventListener("click", () => {
                        mobileMenuToggle.classList.remove("active");
                        navLinks.classList.remove("active");
                    });
                });
            }

            // Dropdown navigation
            const dropdownToggle = document.querySelector(
                ".nav-dropdown-toggle",
            );
            const dropdownMenu = document.querySelector(".nav-dropdown-menu");
            const navDropdown = document.querySelector(".nav-dropdown");

            if (dropdownToggle && dropdownMenu) {
                dropdownToggle.addEventListener("click", (e) => {
                    e.stopPropagation();
                    navDropdown.classList.toggle("active");
                });

                // Close dropdown when clicking outside
                document.addEventListener("click", () => {
                    navDropdown.classList.remove("active");
                });

                navDropdown.addEventListener("click", (e) => {
                    e.stopPropagation();
                });
            }
        </script>

        <Footer locale="en" />
    </body>
</html>

<style>
    /* Reset & Base Styles */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    /* design tokens loaded from tokens.css */

    body {
        font-family: var(--font-primary);
        background-color: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        overflow-x: hidden;
    }

    /* Navigation */
    .navigation {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 60px;
        position: sticky;
        top: 0;
        background-color: var(--color-bg);
        z-index: 1000;
        transition: transform 0.3s ease;
    }

    .logo {
        font-family: var(--font-heading);
        font-size: 32px;
        letter-spacing: -0.32px;
        color: var(--color-text);
    }

    .nav-links {
        display: flex;
        gap: 32px;
        align-items: center;
    }

    .nav-links a {
        color: var(--color-text);
        text-decoration: none;
        font-size: 16px;
        font-weight: 500;
        letter-spacing: -0.48px;
        transition: color 0.3s ease;
    }

    .nav-links a:hover {
        color: var(--accent-deep);
    }

    /* Dropdown Navigation */
    .nav-dropdown {
        position: relative;
    }

    .nav-dropdown-toggle {
        display: flex;
        align-items: center;
        gap: 6px;
        background: none;
        border: none;
        color: var(--color-text);
        font-size: 16px;
        font-weight: 500;
        letter-spacing: -0.48px;
        cursor: pointer;
        padding: 0;
        font-family: var(--font-primary);
        transition: color 0.3s ease;
    }

    .nav-dropdown-toggle:hover {
        color: var(--accent-deep);
    }

    .nav-dropdown-toggle svg {
        transition: transform 0.3s ease;
    }

    .nav-dropdown.active .nav-dropdown-toggle svg {
        transform: rotate(180deg);
    }

    .nav-dropdown-menu {
        position: absolute;
        top: calc(100% + 16px);
        left: 50%;
        transform: translateX(-50%);
        background-color: var(--card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 8px;
        min-width: 160px;
        opacity: 0;
        visibility: hidden;
        transition:
            opacity 0.3s ease,
            visibility 0.3s ease;
        z-index: 1000;
    }

    .nav-dropdown.active .nav-dropdown-menu {
        opacity: 1;
        visibility: visible;
    }

    .nav-dropdown-menu a {
        display: block;
        padding: 12px 16px;
        color: var(--color-text);
        text-decoration: none;
        font-size: 15px;
        border-radius: 8px;
        transition:
            background-color 0.2s ease,
            color 0.2s ease;
    }

    .nav-dropdown-menu a:hover {
        background-color: rgba(79, 94, 29, 0.06);
        color: var(--accent-deep);
    }

    .mobile-menu-toggle {
        display: none;
        flex-direction: column;
        gap: 8px;
        cursor: pointer;
    }

    .mobile-menu-toggle span {
        width: 32px;
        height: 2px;
        background-color: var(--color-text);
        transition: all 0.3s ease;
    }

    /* Page Hero */
    .page-hero {
        padding: 120px 108px 80px;
        border-bottom: 1px solid var(--border);
    }

    .page-hero-content {
        max-width: 900px;
    }

    .page-hero h1 {
        font-family: var(--font-heading);
        font-size: 76px;
        line-height: 1.1;
        letter-spacing: -0.76px;
        color: var(--color-text);
        margin-bottom: 24px;
    }

    .page-hero-subtitle {
        font-size: 24px;
        line-height: 1.4;
        color: var(--color-text);
        opacity: 0.9;
    }

    /* Content Section */
    .content-section {
        padding: 80px 108px;
    }

    .content-wrapper {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 80px;
    }

    .content-main h2 {
        font-family: var(--font-heading);
        font-size: 36px;
        letter-spacing: -0.36px;
        margin-top: 48px;
        margin-bottom: 24px;
        color: var(--color-text);
    }

    .content-main h2:first-child {
        margin-top: 0;
    }

    .content-main p {
        font-size: 17px;
        line-height: 1.7;
        margin-bottom: 20px;
        opacity: 0.95;
    }

    .content-main ul {
        margin: 24px 0 24px 24px;
    }

    .content-main li {
        font-size: 17px;
        line-height: 1.8;
        margin-bottom: 12px;
        opacity: 0.95;
    }

    /* Process Steps */
    .process-steps {
        margin: 48px 0;
    }

    .step {
        display: flex;
        gap: 24px;
        margin-bottom: 40px;
        padding: 32px;
        background-color: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        box-shadow: var(--shadow-card);
    }

    .step-number {
        flex-shrink: 0;
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--color-accent);
        color: var(--on-accent);
        font-family: var(--font-heading);
        font-size: 28px;
        border-radius: 50%;
    }

    .step-content h3 {
        font-size: 22px;
        margin-bottom: 12px;
        color: var(--color-text);
    }

    .step-content p {
        margin: 0;
        font-size: 16px;
        opacity: 0.9;
    }

    .step-tagline {
        color: var(--accent-deep);
        font-weight: 500;
        opacity: 1 !important;
        margin-bottom: 16px !important;
    }

    .step-content ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .step-content ul li {
        font-size: 15px;
        line-height: 1.6;
        opacity: 0.85;
        padding-left: 18px;
        position: relative;
    }

    .step-content ul li::before {
        content: '✓';
        position: absolute;
        left: 0;
        top: 0.16em;
        color: var(--accent-deep);
        font-weight: 700;
        line-height: 1;
        font-size: 12px;
    }

    /* Capabilities List */
    .capabilities-list {
        list-style: none;
        margin: 32px 0;
        padding: 0;
    }

    .capabilities-list li {
        padding-left: 24px;
        position: relative;
        margin-bottom: 16px;
    }

    .capabilities-list li::before {
        content: "✓";
        position: absolute;
        left: 0;
        top: 0.16em;
        color: var(--accent-deep);
        font-weight: 700;
        line-height: 1;
    }

    /* Sidebar */
    .content-sidebar {
        position: sticky;
        top: 96px;
        align-self: start;
    }

    .sidebar-card {
        background-color: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 32px;
        margin-bottom: 24px;
        box-shadow: var(--shadow-card);
    }

    .sidebar-card h3 {
        font-size: 20px;
        margin-bottom: 20px;
        color: var(--color-text);
    }

    .sidebar-card p {
        font-size: 15px;
        line-height: 1.6;
        margin-bottom: 12px;
        opacity: 0.9;
    }

    .sidebar-card ul {
        list-style: none;
        padding: 0;
    }

    .sidebar-card li {
        padding-left: 24px;
        position: relative;
        margin-bottom: 12px;
        font-size: 15px;
        line-height: 1.6;
    }

    .sidebar-card li::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: var(--accent-deep);
        font-weight: 600;
    }

    .cta-card {
        background-color: rgba(211, 233, 122, 0.12);
        border-color: var(--accent-deep);
    }

    .sidebar-cta {
        display: block;
        text-align: center;
        background-color: var(--color-accent);
        color: var(--on-accent);
        padding: 14px 28px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 15px;
        transition:
            transform 0.2s ease,
            background-color 0.2s ease;
        margin-top: 20px;
    }

    .sidebar-cta:hover {
        background-color: #c5db6f;
        transform: translateY(-2px);
    }

    .sidebar-cta-secondary {
        display: block;
        text-align: center;
        color: var(--accent-deep);
        padding: 12px 28px;
        border: 1px solid var(--accent-deep);
        border-radius: 8px;
        text-decoration: none;
        font-weight: 500;
        font-size: 15px;
        transition: background-color 0.2s ease;
        margin-top: 12px;
    }

    .sidebar-cta-secondary:hover {
        background-color: rgba(79, 94, 29, 0.08);
    }

    /* Responsive Design */
    @media (max-width: 1024px) {
        .navigation {
            padding: 24px 32px;
        }

        .page-hero {
            padding: 80px 32px 60px;
        }

        .content-section {
            padding: 60px 32px;
        }

        .content-wrapper {
            grid-template-columns: 1fr;
            gap: 48px;
        }

        .content-sidebar {
            position: static;
        }
    }

    @media (max-width: 768px) {
        .navigation {
            padding: 20px 16px;
        }

        .logo {
            font-size: 28px;
        }

        .nav-links {
            position: fixed;
            top: 76px;
            right: -100%;
            width: 100%;
            height: calc(100vh - 76px);
            background-color: var(--color-bg);
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            padding: 40px 0;
            transition: right 0.3s ease;
            border-top: 1px solid var(--border);
        }

        .nav-links.active {
            right: 0;
        }

        .nav-links a {
            font-size: 24px;
        }

        .nav-dropdown-toggle {
            font-size: 24px;
        }

        .nav-dropdown-menu {
            position: static;
            transform: none;
            margin-top: 16px;
            border: none;
            background-color: transparent;
            padding: 0;
        }

        .nav-dropdown.active .nav-dropdown-menu {
            display: block;
        }

        .nav-dropdown-menu:not(.active) {
            display: none;
        }

        .nav-dropdown-menu a {
            font-size: 20px;
            padding: 12px 0;
        }

        .mobile-menu-toggle {
            display: flex;
        }

        .mobile-menu-toggle.active span:first-child {
            transform: rotate(45deg) translate(8px, 8px);
        }

        .mobile-menu-toggle.active span:last-child {
            transform: rotate(-45deg) translate(8px, -8px);
        }

        .page-hero {
            padding: 60px 16px 40px;
        }

        .page-hero h1 {
            font-size: 48px;
        }

        .page-hero-subtitle {
            font-size: 18px;
        }

        .content-section {
            padding: 40px 16px;
        }

        .step {
            flex-direction: column;
            padding: 24px;
        }
    }

/* Consulting & Implementation intro */
.engagement-intro {
    margin-bottom: 64px;
}

.engagement-intro > p {
    margin-bottom: 32px;
}

.engagement-paths {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
}

.engagement-path {
