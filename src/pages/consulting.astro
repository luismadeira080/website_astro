---
import SEO from "../components/SEO.astro";
import Schema from "../components/Schema.astro";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <!-- Google Tag Manager -->
        <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-WHTQCRZ4');</script>
        <!-- End Google Tag Manager -->
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="/favicon-32x32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href="/favicon-16x16.png"
        />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/apple-touch-icon.png"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600&display=swap"
            rel="stylesheet"
        />

        <!-- SEO Meta Tags -->
        <SEO
            title="AI Consulting - Luís Madeira | Your Ongoing AI Partner"
            description="Ongoing AI partner for SMEs. I map your business for highest-ROI opportunities, build reliable and auditable AI processes, and stay with you as your operations evolve."
            locale="en"
        />

        <!-- Structured Data -->
        <Schema type="Organization" />
    </head>
    <body>
        <!-- Google Tag Manager (noscript) -->
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WHTQCRZ4"
        height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
        <!-- End Google Tag Manager (noscript) -->
        <!-- Navigation -->
        <nav class="navigation">
            <a href="/" class="logo">luís madeira</a>
            <div class="nav-links">
                <a href="/consulting">Services</a>
                <a href="/projects">Projects</a>
                <a href="/about">About</a>
                <a href="/#contact">Contact</a>
                <LanguageSwitcher currentPath="/consulting" />
            </div>
            <div class="mobile-menu-toggle">
                <span></span>
                <span></span>
            </div>
        </nav>

        <!-- Hero Section -->
        <section class="page-hero">
            <div class="page-hero-content">
                <h1>YOUR ONGOING AI PARTNER</h1>
                <p class="page-hero-subtitle">
                    I map your business to find the highest-ROI opportunities for AI, then build reliable processes that deliver consistent, auditable results. Not a one-off project — an ongoing partnership.
                </p>
            </div>
        </section>

        <!-- Main Content -->
        <section class="content-section">
            <div class="content-wrapper">
                <div class="content-main">
                    <h2>It Starts With Mapping Your Business</h2>
                    <p>
                        Before touching any tool, I do a deep dive into your operations. I map every area of your business to identify where AI would generate the most ROI — not where it's flashiest, but where it moves the needle.
                    </p>
                    <p>
                        This mapping produces a prioritized roadmap: which processes to automate first, what the expected impact is, and how to measure success. You know exactly where your money goes before anything is built.
                    </p>

                    <h2>Reliability & Determinism, Not Magic</h2>
                    <p>
                        Most AI demos look impressive. Most AI in production fails silently. I focus on building processes that are <strong>reliable, deterministic, and auditable</strong> — you can trace every output back to its inputs and understand exactly why a result was produced.
                    </p>
                    <ul>
                        <li>
                            <strong>Consistent outputs:</strong> Same input, same result. Every time.
                        </li>
                        <li>
                            <strong>Auditable processes:</strong> Full traceability from data in to decision out.
                        </li>
                        <li>
                            <strong>Failure handling:</strong> When something breaks, it flags — it doesn't guess.
                        </li>
                        <li>
                            <strong>Human oversight:</strong> AI augments decisions, humans stay in control.
                        </li>
                    </ul>

                    <h2>How The Partnership Works</h2>
                    <p>
                        I'm not a consultant who delivers a report and leaves. I work as your ongoing AI partner — embedded in your operations, evolving processes as your business changes.
                    </p>

                    <div class="process-steps">
                        <div class="step">
                            <div class="step-number">1</div>
                            <div class="step-content">
                                <h3>Map & Prioritize</h3>
                                <p>
                                    Deep-dive into your business operations. I identify every area where AI can generate ROI and rank them by impact, effort, and risk.
                                </p>
                            </div>
                        </div>

                        <div class="step">
                            <div class="step-number">2</div>
                            <div class="step-content">
                                <h3>Build & Validate</h3>
                                <p>
                                    I implement the highest-priority processes first. Every workflow is tested for reliability, edge cases are handled, and outputs are validated before going live.
                                </p>
                            </div>
                        </div>

                        <div class="step">
                            <div class="step-number">3</div>
                            <div class="step-content">
                                <h3>Evolve & Expand</h3>
                                <p>
                                    As your business changes, so do the processes. I stay with you to optimize what's running, tackle the next priority on the roadmap, and train your team along the way.
                                </p>
                            </div>
                        </div>
                    </div>

                    <h2>Who This Is For</h2>
                    <p>I work with SMEs that:</p>
                    <ul>
                        <li>Want a long-term AI partner, not a one-off project</li>
                        <li>Need to understand where AI generates real ROI in their business</li>
                        <li>Value reliability and consistency over flashy demos</li>
                        <li>Want auditable processes they can trust and explain</li>
                        <li>Seek to increase capacity without hiring more people</li>
                    </ul>
                </div>

                <div class="content-sidebar">
                    <div class="sidebar-card">
                        <h3>What You Get</h3>
                        <ul>
                            <li>Full business mapping for AI opportunities</li>
                            <li>ROI-prioritized implementation roadmap</li>
                            <li>Reliable, deterministic AI processes</li>
                            <li>Ongoing partnership as your business evolves</li>
                        </ul>
                    </div>

                    <div class="sidebar-card">
                        <h3>My Principles</h3>
                        <p>Reliability over novelty</p>
                        <p>Auditable outputs, always</p>
                        <p>ROI-first prioritization</p>
                        <p>Ongoing partner, not one-off vendor</p>
                    </div>

                    <div class="sidebar-card cta-card">
                        <h3>Let's Talk</h3>
                        <p>
                            If it makes sense to explore how AI can transform
                            your business, let's talk.
                        </p>
                        <a
                            href="mailto:luismadeira@ruimadeira.pt"
                            class="sidebar-cta">Send Email</a
                        >
                        <a
                            href="https://www.linkedin.com/in/lumadeira"
                            target="_blank"
                            class="sidebar-cta-secondary">LinkedIn</a
                        >
                    </div>
                </div>
            </div>
        </section>

        <script>
            // Mobile Menu Toggle
            const mobileMenuToggle = document.querySelector(
                ".mobile-menu-toggle",
            );
            const navLinks = document.querySelector(".nav-links");

            if (mobileMenuToggle) {
                mobileMenuToggle.addEventListener("click", () => {
                    mobileMenuToggle.classList.toggle("active");
                    navLinks.classList.toggle("active");
                });

                // Close menu when clicking on a link
                const links = navLinks.querySelectorAll("a");
                links.forEach((link) => {
                    link.addEventListener("click", () => {
                        mobileMenuToggle.classList.remove("active");
                        navLinks.classList.remove("active");
                    });
                });
            }

            // Dropdown navigation
            const dropdownToggle = document.querySelector(
                ".nav-dropdown-toggle",
            );
            const dropdownMenu = document.querySelector(".nav-dropdown-menu");
            const navDropdown = document.querySelector(".nav-dropdown");

            if (dropdownToggle && dropdownMenu) {
                dropdownToggle.addEventListener("click", (e) => {
                    e.stopPropagation();
                    navDropdown.classList.toggle("active");
                });

                // Close dropdown when clicking outside
                document.addEventListener("click", () => {
                    navDropdown.classList.remove("active");
                });

                navDropdown.addEventListener("click", (e) => {
                    e.stopPropagation();
                });
            }
        </script>

        <Footer locale="en" />
    </body>
</html>

<style>
    /* Reset & Base Styles */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --color-bg: #0d0d0d;
        --color-text: #c7c7c7;
        --color-accent: #d3e97a;
        --color-dark: #1a1a1a;
        --font-primary: "Inter", sans-serif;
        --font-heading: "Bebas Neue", sans-serif;
    }

    body {
        font-family: var(--font-primary);
        background-color: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        overflow-x: hidden;
    }

    /* Navigation */
    .navigation {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 60px;
        position: sticky;
        top: 0;
        background-color: var(--color-bg);
        z-index: 1000;
        transition: transform 0.3s ease;
    }

    .logo {
        font-family: var(--font-heading);
        font-size: 32px;
        letter-spacing: -0.32px;
        color: var(--color-text);
    }

    .nav-links {
        display: flex;
        gap: 32px;
        align-items: center;
    }

    .nav-links a {
        color: var(--color-text);
        text-decoration: none;
        font-size: 16px;
        font-weight: 500;
        letter-spacing: -0.48px;
        transition: color 0.3s ease;
    }

    .nav-links a:hover {
        color: var(--color-accent);
    }

    /* Dropdown Navigation */
    .nav-dropdown {
        position: relative;
    }

    .nav-dropdown-toggle {
        display: flex;
        align-items: center;
        gap: 6px;
        background: none;
        border: none;
        color: var(--color-text);
        font-size: 16px;
        font-weight: 500;
        letter-spacing: -0.48px;
        cursor: pointer;
        padding: 0;
        font-family: var(--font-primary);
        transition: color 0.3s ease;
    }

    .nav-dropdown-toggle:hover {
        color: var(--color-accent);
    }

    .nav-dropdown-toggle svg {
        transition: transform 0.3s ease;
    }

    .nav-dropdown.active .nav-dropdown-toggle svg {
        transform: rotate(180deg);
    }

    .nav-dropdown-menu {
        position: absolute;
        top: calc(100% + 16px);
        left: 50%;
        transform: translateX(-50%);
        background-color: var(--color-dark);
        border: 1px solid #333;
        border-radius: 12px;
        padding: 8px;
        min-width: 160px;
        opacity: 0;
        visibility: hidden;
        transition:
            opacity 0.3s ease,
            visibility 0.3s ease;
        z-index: 1000;
    }

    .nav-dropdown.active .nav-dropdown-menu {
        opacity: 1;
        visibility: visible;
    }

    .nav-dropdown-menu a {
        display: block;
        padding: 12px 16px;
        color: var(--color-text);
        text-decoration: none;
        font-size: 15px;
        border-radius: 8px;
        transition:
            background-color 0.2s ease,
            color 0.2s ease;
    }

    .nav-dropdown-menu a:hover {
        background-color: rgba(211, 233, 122, 0.1);
        color: var(--color-accent);
    }

    .mobile-menu-toggle {
        display: none;
        flex-direction: column;
        gap: 8px;
        cursor: pointer;
    }

    .mobile-menu-toggle span {
        width: 32px;
        height: 2px;
        background-color: var(--color-text);
        transition: all 0.3s ease;
    }

    /* Page Hero */
    .page-hero {
        padding: 120px 108px 80px;
        border-bottom: 1px solid #333;
    }

    .page-hero-content {
        max-width: 900px;
    }

    .page-hero h1 {
        font-family: var(--font-heading);
        font-size: 76px;
        line-height: 1.1;
        letter-spacing: -0.76px;
        color: var(--color-text);
        margin-bottom: 24px;
    }

    .page-hero-subtitle {
        font-size: 24px;
        line-height: 1.4;
        color: var(--color-text);
        opacity: 0.9;
    }

    /* Content Section */
    .content-section {
        padding: 80px 108px;
    }

    .content-wrapper {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 80px;
    }

    .content-main h2 {
        font-family: var(--font-heading);
        font-size: 36px;
        letter-spacing: -0.36px;
        margin-top: 48px;
        margin-bottom: 24px;
        color: var(--color-text);
    }

    .content-main h2:first-child {
        margin-top: 0;
    }

    .content-main p {
        font-size: 17px;
        line-height: 1.7;
        margin-bottom: 20px;
        opacity: 0.95;
    }

    .content-main ul {
        margin: 24px 0 24px 24px;
    }

    .content-main li {
        font-size: 17px;
        line-height: 1.8;
        margin-bottom: 12px;
        opacity: 0.95;
    }

    /* Process Steps */
    .process-steps {
        margin: 48px 0;
    }

    .step {
        display: flex;
        gap: 24px;
        margin-bottom: 40px;
        padding: 32px;
        background-color: var(--color-dark);
        border: 1px solid #333;
        border-radius: 16px;
    }

    .step-number {
        flex-shrink: 0;
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--color-accent);
        color: var(--color-bg);
        font-family: var(--font-heading);
        font-size: 28px;
        border-radius: 50%;
    }

    .step-content h3 {
        font-size: 22px;
        margin-bottom: 12px;
        color: var(--color-text);
    }

    .step-content p {
        margin: 0;
        font-size: 16px;
        opacity: 0.9;
    }

    /* Capabilities List */
    .capabilities-list {
        list-style: none;
        margin: 32px 0;
        padding: 0;
    }

    .capabilities-list li {
        padding-left: 32px;
        position: relative;
        margin-bottom: 16px;
    }

    .capabilities-list li::before {
        content: "→";
        position: absolute;
        left: 0;
        color: var(--color-accent);
        font-weight: 600;
    }

    /* Sidebar */
    .content-sidebar {
        position: sticky;
        top: 96px;
        align-self: start;
    }

    .sidebar-card {
        background-color: var(--color-dark);
        border: 1px solid #333;
        border-radius: 16px;
        padding: 32px;
        margin-bottom: 24px;
    }

    .sidebar-card h3 {
        font-size: 20px;
        margin-bottom: 20px;
        color: var(--color-text);
    }

    .sidebar-card p {
        font-size: 15px;
        line-height: 1.6;
        margin-bottom: 12px;
        opacity: 0.9;
    }

    .sidebar-card ul {
        list-style: none;
        padding: 0;
    }

    .sidebar-card li {
        padding-left: 24px;
        position: relative;
        margin-bottom: 12px;
        font-size: 15px;
        line-height: 1.6;
    }

    .sidebar-card li::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: var(--color-accent);
        font-weight: 600;
    }

    .cta-card {
        background-color: rgba(211, 233, 122, 0.05);
        border-color: var(--color-accent);
    }

    .sidebar-cta {
        display: block;
        text-align: center;
        background-color: var(--color-accent);
        color: var(--color-bg);
        padding: 14px 28px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 15px;
        transition:
            transform 0.2s ease,
            background-color 0.2s ease;
        margin-top: 20px;
    }

    .sidebar-cta:hover {
        background-color: #c5db6f;
        transform: translateY(-2px);
    }

    .sidebar-cta-secondary {
        display: block;
        text-align: center;
        color: var(--color-accent);
        padding: 12px 28px;
        border: 1px solid var(--color-accent);
        border-radius: 8px;
        text-decoration: none;
        font-weight: 500;
        font-size: 15px;
        transition: background-color 0.2s ease;
        margin-top: 12px;
    }

    .sidebar-cta-secondary:hover {
        background-color: rgba(211, 233, 122, 0.1);
    }

    /* Responsive Design */
    @media (max-width: 1024px) {
        .navigation {
            padding: 24px 32px;
        }

        .page-hero {
            padding: 80px 32px 60px;
        }

        .content-section {
            padding: 60px 32px;
        }

        .content-wrapper {
            grid-template-columns: 1fr;
            gap: 48px;
        }

        .content-sidebar {
            position: static;
        }
    }

    @media (max-width: 768px) {
        .navigation {
            padding: 20px 16px;
        }

        .logo {
            font-size: 28px;
        }

        .nav-links {
            position: fixed;
            top: 76px;
            right: -100%;
            width: 100%;
            height: calc(100vh - 76px);
            background-color: var(--color-bg);
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            padding: 40px 0;
            transition: right 0.3s ease;
            border-top: 1px solid #333;
        }

        .nav-links.active {
            right: 0;
        }

        .nav-links a {
            font-size: 24px;
        }

        .nav-dropdown-toggle {
            font-size: 24px;
        }

        .nav-dropdown-menu {
            position: static;
            transform: none;
            margin-top: 16px;
            border: none;
            background-color: transparent;
            padding: 0;
        }

        .nav-dropdown.active .nav-dropdown-menu {
            display: block;
        }

        .nav-dropdown-menu:not(.active) {
            display: none;
        }

        .nav-dropdown-menu a {
            font-size: 20px;
            padding: 12px 0;
        }

        .mobile-menu-toggle {
            display: flex;
        }

        .mobile-menu-toggle.active span:first-child {
            transform: rotate(45deg) translate(8px, 8px);
        }

        .mobile-menu-toggle.active span:last-child {
            transform: rotate(-45deg) translate(8px, -8px);
        }

        .page-hero {
            padding: 60px 16px 40px;
        }

        .page-hero h1 {
            font-size: 48px;
        }

        .page-hero-subtitle {
            font-size: 18px;
        }

        .content-section {
            padding: 40px 16px;
        }

        .step {
            flex-direction: column;
            padding: 24px;
        }
    }
</style>
