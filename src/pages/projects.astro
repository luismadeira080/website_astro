---
import SEO from '../components/SEO.astro';
import Schema from '../components/Schema.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import ContactModal from '../components/ContactModal.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-WHTQCRZ4');</script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <!-- SEO Meta Tags -->
    <SEO
        title="Projects by Sector - AI Workflow Results | Luís Madeira"
        description="See real outcomes from AI workflow automation across e-commerce, sales, operations, and customer support. Metrics-driven results for Portuguese businesses."
        locale="en"
    />

    <!-- Structured Data -->
    <Schema type="Organization" />
</head>
<body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WHTQCRZ4"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <!-- Navigation -->
    <nav class="navigation">
        <a href="/" class="logo">luís madeira</a>
        <div class="nav-links">
            <a href="/consulting">Services</a>
            <a href="/projects">What I Do</a>
            <a href="/about">About</a>
            <a href="/#contact">Contact</a>
            <LanguageSwitcher currentPath="/projects" />
        </div>
        <div class="mobile-menu-toggle">
            <span></span>
            <span></span>
        </div>
    </nav>

    <!-- Hero -->
    <section class="projects-hero">
        <h1>PROJECTS</h1>
        <p>AI automation outcomes across the sectors where I work</p>
    </section>

    <!-- Sectors -->
    <section class="sectors">

        <!-- Sales & Lead Management -->
        <div class="sector" id="sales">
            <div class="sector-header">
                <div class="sector-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>
                <div>
                    <h2>SALES & LEAD MANAGEMENT</h2>
                    <p class="sector-tagline">Faster responses, cleaner data, full pipeline visibility</p>
                </div>
            </div>
            <div class="outcomes-grid">
                <div class="outcome-card">
                    <div class="outcome-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
                        </svg>
                    </div>
                    <h3>Database reactivation</h3>
                    <p>Re-engage past customers and cold leads who already know your brand. Revenue from data you already have, no extra ad spend.</p>
                    <div class="metric">Cold Leads &rarr; Warm Sales</div>
                </div>
                <div class="outcome-card">
                    <div class="outcome-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                        </svg>
                    </div>
                    <h3>Respond to leads in seconds</h3>
                    <p>Automated lead qualification and instant response.</p>
                    <div class="metric">Hours &rarr; Seconds</div>
                </div>
                <div class="outcome-card">
                    <div class="outcome-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                        </svg>
                    </div>
                    <h3>CRM that fills itself</h3>
                    <p>Auto-enrichment of contact data, interaction summaries, and next-step suggestions.</p>
                    <div class="metric">Manual &rarr; Automated</div>
                </div>
            </div>
        </div>

        <!-- E-Commerce -->
        <div class="sector" id="ecommerce">
            <div class="sector-header">
                <div class="sector-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                    </svg>
                </div>
                <div>
                    <h2>E-COMMERCE</h2>
                    <p class="sector-tagline">Inventory, margins, and profitability on autopilot</p>
                </div>
            </div>
            <div class="outcomes-grid">
                <div class="outcome-card">
                    <div class="outcome-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                            <line x1="12" y1="22.08" x2="12" y2="12"/>
                        </svg>
                    </div>
                    <h3>Never run out of stock</h3>
                    <p>Automated inventory alerts that flag low-coverage SKUs before stockouts happen.</p>
                    <div class="metric">Reactive &rarr; Proactive</div>
                </div>
                <div class="outcome-card">
                    <div class="outcome-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                        </svg>
                    </div>
                    <h3>Monthly P&L in minutes</h3>
                    <p>Automated analysis of your core business data — month-over-month trends, channel performance, and anomaly alerts.</p>
                    <div class="metric">Days &rarr; Minutes</div>
                </div>
                <div class="outcome-card">
                    <div class="outcome-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
                        </svg>
                    </div>
                    <h3>Find your margin killers</h3>
                    <p>Per-SKU profitability analysis that surfaces repricing and discontinuation targets.</p>
                    <div class="metric">Hidden &rarr; Visible</div>
                </div>
            </div>
        </div>

        <!-- Operations & Internal -->
        <div class="sector" id="operations">
            <div class="sector-header">
                <div class="sector-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                </div>
                <div>
                    <h2>OPERATIONS & INTERNAL</h2>
                    <p class="sector-tagline">Reports, documents, and admin work that runs itself</p>
                </div>
            </div>
            <div class="outcomes-grid outcomes-grid--two">
                <div class="outcome-card">
                    <div class="outcome-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
                        </svg>
                    </div>
                    <h3>Client reports that write themselves</h3>
                    <p>Auto-generated monthly reports from your existing data.</p>
                    <div class="metric">Hours &rarr; Minutes</div>
                </div>
                <div class="outcome-card">
                    <div class="outcome-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/>
                        </svg>
                    </div>
                    <h3>Invoices and contracts, structured</h3>
                    <p>Extract data from documents into structured, usable formats.</p>
                    <div class="metric">PDF &rarr; Structured Data</div>
                </div>
            </div>
        </div>


    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <h2>WHICH SECTOR IS YOURS?</h2>
        <p>Tell me what's eating your team's time and we'll figure out what AI can do about it.</p>
        <a href="/#contact" class="btn-primary">Get in touch</a>
    </section>

    <script>
        // Mobile Menu Toggle
        const mobileMenuToggle = document.querySelector('.mobile-menu-toggle');
        const navLinks = document.querySelector('.nav-links');

        if (mobileMenuToggle) {
            mobileMenuToggle.addEventListener('click', () => {
                mobileMenuToggle.classList.toggle('active');
                navLinks.classList.toggle('active');
            });

            const links = navLinks.querySelectorAll('a');
            links.forEach(link => {
                link.addEventListener('click', () => {
                    mobileMenuToggle.classList.remove('active');
                    navLinks.classList.remove('active');
                });
            });
        }
    </script>
    <ContactModal locale="en" context="general" />
</body>
</html>

<style>
/* Reset & Base Styles */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --color-bg: #0d0d0d;
    --color-text: #c7c7c7;
    --color-accent: #d3e97a;
    --color-dark: #1a1a1a;
    --font-primary: 'Inter', sans-serif;
    --font-heading: 'Bebas Neue', sans-serif;
}

body {
    font-family: var(--font-primary);
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    overflow-x: hidden;
}

/* Navigation */
.navigation {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 60px;
    position: sticky;
    top: 0;
    background-color: var(--color-bg);
    z-index: 1000;
    transition: transform 0.3s ease;
}

.logo {
    font-family: var(--font-heading);
    font-size: 32px;
    letter-spacing: -0.32px;
    color: var(--color-text);
    text-decoration: none;
}

.nav-links {
    display: flex;
    gap: 32px;
}

.nav-links a {
    color: var(--color-text);
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.48px;
    transition: color 0.3s ease;
}

.nav-links a:hover {
    color: var(--color-accent);
}

.mobile-menu-toggle {
    display: none;
    flex-direction: column;
    gap: 8px;
    cursor: pointer;
}

.mobile-menu-toggle span {
    width: 32px;
    height: 2px;
    background-color: var(--color-text);
    transition: all 0.3s ease;
}

/* Hero */
.projects-hero {
    padding: 120px 108px 80px;
    text-align: center;
}

.projects-hero h1 {
    font-family: var(--font-heading);
    font-size: 88px;
    letter-spacing: -0.88px;
    margin-bottom: 16px;
}

.projects-hero p {
    font-size: 20px;
    color: var(--color-text);
    opacity: 0.7;
}

/* Sectors */
.sectors {
    padding: 0 108px 40px;
    display: flex;
    flex-direction: column;
    gap: 64px;
}

.sector {
    border: 1px solid #333;
    border-radius: 16px;
    padding: 48px;
    background-color: var(--color-dark);
}

.sector--featured {
    border-color: rgba(211, 233, 122, 0.25);
    background: linear-gradient(180deg, rgba(211, 233, 122, 0.04) 0%, var(--color-dark) 100%);
}

.sector-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 40px;
}

.sector-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background-color: rgba(211, 233, 122, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    flex-shrink: 0;
}

.sector-header h2 {
    font-family: var(--font-heading);
    font-size: 40px;
    letter-spacing: -0.4px;
    line-height: 1;
    margin-bottom: 4px;
}

.sector-tagline {
    font-size: 15px;
    opacity: 0.6;
}

/* Outcomes Grid */
.outcomes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}

.outcomes-grid--two {
    grid-template-columns: repeat(2, 1fr);
}

.outcome-card {
    background-color: var(--color-bg);
    border: 1px solid #333;
    border-radius: 12px;
    padding: 28px;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.3s ease;
}

.outcome-card:hover {
    border-color: rgba(211, 233, 122, 0.3);
}

.outcome-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    background-color: rgba(211, 233, 122, 0.12);
    color: var(--color-accent);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 4px 10px;
    border-radius: 6px;
}

.outcome-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background-color: rgba(211, 233, 122, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
}

.outcome-card h3 {
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    line-height: 1.3;
}

.outcome-card p {
    font-size: 14px;
    line-height: 1.5;
    opacity: 0.7;
}

.metric {
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid #333;
    font-family: var(--font-heading);
    font-size: 20px;
    color: var(--color-accent);
    letter-spacing: 0.5px;
}

/* CTA Section */
.cta-section {
    padding: 80px 108px;
    text-align: center;
    border-top: 1px solid #333;
    margin-top: 40px;
}

.cta-section h2 {
    font-family: var(--font-heading);
    font-size: 64px;
    letter-spacing: -0.64px;
    margin-bottom: 20px;
}

.cta-section p {
    font-size: 18px;
    margin-bottom: 32px;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
    opacity: 0.8;
}

.btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background-color: var(--color-accent);
    color: var(--color-bg);
    padding: 16px 32px;
    border-radius: 27px;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.5px;
    transition: transform 0.3s ease, background-color 0.3s ease;
}

.btn-primary:hover {
    background-color: #c5db6f;
    transform: translateY(-2px);
}

/* Responsive: Tablet */
@media (max-width: 1024px) {
    .navigation {
        padding: 24px 32px;
    }

    .projects-hero {
        padding: 80px 32px 60px;
    }

    .projects-hero h1 {
        font-size: 72px;
    }

    .sectors {
        padding: 0 32px 40px;
        gap: 48px;
    }

    .sector {
        padding: 36px;
    }

    .sector-header h2 {
        font-size: 34px;
    }

    .outcomes-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .outcomes-grid--two {
        grid-template-columns: repeat(2, 1fr);
    }

    .cta-section {
        padding: 60px 32px;
    }

    .cta-section h2 {
        font-size: 52px;
    }
}

/* Responsive: Mobile */
@media (max-width: 768px) {
    .navigation {
        padding: 20px 16px;
    }

    .logo {
        font-size: 28px;
    }

    .nav-links {
        position: fixed;
        top: 76px;
        right: -100%;
        width: 100%;
        height: calc(100vh - 76px);
        background-color: var(--color-bg);
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding: 40px 0;
        transition: right 0.3s ease;
        border-top: 1px solid #333;
    }

    .nav-links.active {
        right: 0;
    }

    .nav-links a {
        font-size: 24px;
    }

    .mobile-menu-toggle {
        display: flex;
    }

    .mobile-menu-toggle.active span:first-child {
        transform: rotate(45deg) translate(8px, 8px);
    }

    .mobile-menu-toggle.active span:last-child {
        transform: rotate(-45deg) translate(8px, -8px);
    }

    .projects-hero {
        padding: 60px 16px 40px;
    }

    .projects-hero h1 {
        font-size: 57px;
    }

    .projects-hero p {
        font-size: 17px;
    }

    .sectors {
        padding: 0 16px 32px;
        gap: 32px;
    }

    .sector {
        padding: 24px;
    }

    .sector-header {
        margin-bottom: 28px;
    }

    .sector-header h2 {
        font-size: 28px;
    }

    .sector-tagline {
        font-size: 14px;
    }

    .outcomes-grid,
    .outcomes-grid--two {
        grid-template-columns: 1fr;
        gap: 16px;
    }

    .outcome-card {
        padding: 22px;
    }

    .outcome-card h3 {
        font-size: 16px;
    }

    .metric {
        font-size: 18px;
    }

    .cta-section {
        padding: 48px 16px;
    }

    .cta-section h2 {
        font-size: 42px;
    }

    .cta-section p {
        font-size: 16px;
    }
}

/* Responsive: Small mobile */
@media (max-width: 480px) {
    .projects-hero h1 {
        font-size: 48px;
    }

    .sector-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }

    .sector-header h2 {
        font-size: 24px;
    }

    .cta-section h2 {
        font-size: 36px;
    }
}
</style>
