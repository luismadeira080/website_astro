import Schema from '../components/Schema.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import Footer from '../components/Footer.astro';
import '../styles/tokens.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
