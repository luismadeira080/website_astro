<body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WHTQCRZ4"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <!-- Navigation -->
    <nav class="navigation">
        <a href="/" class="logo">luís madeira</a>
        <div class="nav-links">
            <a href="/services">Services</a>
            <a href="#about">About</a>
            <a href="#contact">Contact</a>
            <LanguageSwitcher currentPath="/" />
        </div>
        <div class="mobile-menu-toggle">
            <span></span>
            <span></span>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <div class="hero-text">
                <h1>ENABLING GROWTH THROUGH AI-POWERED SOLUTIONS.</h1>
                <p class="hero-subtitle">I build AI-powered internal solutions, tailored to how your business actually works.</p>
            </div>
            <div class="hero-actions">
                <a href="/ai-contact" class="btn-primary">Let's talk</a>
            </div>
        </div>
        <div class="hero-image">
            <img src="/profile.jpeg" alt="Luís Madeira">
        </div>
    </section>

    <!-- My Process -->
    <section class="our-process-section">
        <div class="process-header reveal">
            <span class="process-kicker">HOW I WORK</span>
            <h2>MY PROCESS</h2>
            <p>A methodical, low-risk approach: I start by understanding the business, not jumping straight into tools.</p>
        </div>

        <div class="process-grid">
            <div class="process-card reveal">
                <div class="process-card-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                </div>
                <div class="process-card-badge">01</div>
                <div class="card-content">
                    <h3>Operations Audit</h3>
                    <p class="process-tagline">Understand the business before building anything.</p>
                    <ul class="process-bullets">
                        <li>I map your operations end-to-end: how work moves, where data lives, where time gets lost.</li>
                        <li>I identify where AI-powered internal solutions generate the most ROI in your specific business.</li>
                        <li>You get a prioritized roadmap: what to tackle first, what impact to expect, how I'll measure it.</li>
                    </ul>
                </div>
            </div>

            <div class="process-card reveal">
                <div class="process-card-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                    </svg>
                </div>
                <div class="process-card-badge">02</div>
                <div class="card-content">
                    <h3>Implementation</h3>
                    <p class="process-tagline">Tailored to your operations, not off-the-shelf.</p>
                    <ul class="process-bullets">
                        <li>I build it around how your business actually works: workflow automation, data consolidation, process redesign, invoice processing, reporting, and similar patterns.</li>
                        <li>Every solution is scoped to your specific case, not a generic template.</li>
                        <li>Your team learns how it works as I build it. No black boxes.</li>
                    </ul>
                </div>
            </div>

            <div class="process-card reveal">
                <div class="process-card-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
                        <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
                    </svg>
                </div>
                <div class="process-card-badge">03</div>
                <div class="card-content">
                    <h3>Ongoing Support</h3>
