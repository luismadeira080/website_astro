                        <ellipse cx="12" cy="5" r="9"/><path d="M3 5v14a9 9 0 0 0 18 0V5"/><path d="M3 12a9 9 0 0 0 18 0"/>
                    </svg>
                </div>
                <h3>Data & Integration Layer</h3>
                <p class="sector-card-line">Your scattered systems, joined into one source of truth.</p>
            </a>

            <a href="/services#operations-admin" class="sector-card reveal">
                <div class="sector-card-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/>
                    </svg>
                </div>
                <h3>Operations & Admin</h3>
                <p class="sector-card-line">The repetitive back-office work, handled in the background.</p>
            </a>
        </div>

        <aside class="sectors-rail reveal">
            <span class="sectors-rail-label">I also build</span>
            <a href="/services#idp" class="sectors-rail-item">
                <h3>Intelligent Document Processing</h3>
                <svg class="sectors-rail-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
            </a>
            <a href="/services#dashboards" class="sectors-rail-item">
                <h3>AI-Powered Dashboards</h3>
                <svg class="sectors-rail-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
            </a>
            <a href="/services#sales" class="sectors-rail-item">
                <h3>Sales & Revenue Predictions</h3>
                <svg class="sectors-rail-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
            </a>
        </aside>
        </div>

        <div class="sectors-cta">
            <a href="/services" class="text-link">SEE YOUR SOLUTIONS</a>
        </div>
    </section>

    <!-- Social Proof Section -->
    <section class="testimonials-section">
        <div class="section-header reveal">
            <h2>Results</h2>
            <p>What clients have been able to do differently.</p>
        </div>
        <div class="testimonials-grid">
            <div class="testimonial-card reveal">
                <p class="testimonial-quote">"[PLACEHOLDER — client quote tied to a specific outcome, e.g. 'We went from spending 2 days a week on reporting to having it ready every morning automatically.']"</p>
                <div class="testimonial-author">
                    <strong>[Client Name]</strong>
                    <span>[Role, Company]</span>
                </div>
            </div>
            <div class="testimonial-card reveal">
                <p class="testimonial-quote">"[PLACEHOLDER — client quote tied to a specific outcome]"</p>
                <div class="testimonial-author">
                    <strong>[Client Name]</strong>
                    <span>[Role, Company]</span>
                </div>
            </div>
            <div class="testimonial-card reveal">
                <p class="testimonial-quote">"[PLACEHOLDER — client quote tied to a specific outcome]"</p>
                <div class="testimonial-author">
                    <strong>[Client Name]</strong>
                    <span>[Role, Company]</span>
                </div>
            </div>
        </div>
    </section>

    <!-- About Me Section -->
    <section id="about" class="about-section">
        <h2>ABOUT ME</h2>
        <div class="about-content reveal">
            <div class="about-intro">
                <h3>I understand business models, not just tools.</h3>
            </div>
            <div class="about-description">
                <p>Before this, I spent two years in Venture Capital, evaluating businesses, understanding unit economics, and figuring out what actually drives growth. That's the lens I bring to every project: where does the investment pay off, and what's the fastest path to results.</p>
                <a href="/about" class="text-link">MORE ABOUT ME</a>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact-section-simple">
        <div class="contact-container reveal">
            <div class="cta-content">
                <h2>Let's talk about your business</h2>
                <p class="cta-subtext">Tell me what's slowing you down. I'll tell you what I can do about it.</p>
                <a href="/ai-contact" class="cta-button">Get in touch</a>
            </div>
            <div class="cta-background-text">LM</div>
        </div>
    </section>

    <script>
        // Mobile Menu Toggle
        const mobileMenuToggle = document.querySelector('.mobile-menu-toggle');
        const navLinks = document.querySelector('.nav-links');

        if (mobileMenuToggle) {
            mobileMenuToggle.addEventListener('click', () => {
                mobileMenuToggle.classList.toggle('active');
                navLinks.classList.toggle('active');
            });

            // Close menu when clicking on a link
            const links = navLinks.querySelectorAll('a');
            links.forEach(link => {
                link.addEventListener('click', () => {
                    mobileMenuToggle.classList.remove('active');
                    navLinks.classList.remove('active');
                });
            });
        }

        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Add scroll effect to navigation
        let lastScroll = 0;
        const nav = document.querySelector('.navigation');

        window.addEventListener('scroll', () => {
            const currentScroll = window.pageYOffset;

            if (currentScroll > lastScroll && currentScroll > 100) {
                nav.style.transform = 'translateY(-100%)';
            } else {
                nav.style.transform = 'translateY(0)';
            }

            lastScroll = currentScroll;
        });

        // Scroll reveal (shared .reveal / .in-view utility from tokens.css)
        const revealEls = document.querySelectorAll(".reveal");
        if (revealEls.length && "IntersectionObserver" in window) {
            const revealIO = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("in-view");
                            revealIO.unobserve(entry.target);
                        }
                    });
                },
                { threshold: 0.12, rootMargin: "0px 0px -8% 0px" },
            );
            revealEls.forEach((el) => revealIO.observe(el));
        } else {
            revealEls.forEach((el) => el.classList.add("in-view"));
        }

    </script>

    <Footer locale="en" />
</body>
</html>

<style>
/* Reset & Base Styles */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* Design tokens now come from the global light theme: ../styles/tokens.css
   (legacy --color-* names are aliased there to the new light values). */

body {
    font-family: var(--font-primary);
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    overflow-x: hidden;
}

/* Navigation */
.navigation {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 60px;
    position: sticky;
    top: 0;
    background-color: var(--color-bg);
    z-index: 1000;
    transition: transform 0.3s ease;
}

.logo {
    font-family: var(--font-heading);
    font-size: 32px;
    letter-spacing: -0.32px;
    color: var(--color-text);
}

.nav-links {
    display: flex;
    gap: 32px;
}

.nav-links a {
    color: var(--color-text);
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.48px;
    transition: color 0.3s ease;
}

.nav-links a:hover {
    color: var(--accent-deep);
}

/* Dropdown Navigation */
.nav-dropdown {
    position: relative;
}

.nav-dropdown-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    color: var(--color-text);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.48px;
    cursor: pointer;
    padding: 0;
    font-family: var(--font-primary);
    transition: color 0.3s ease;
}

.nav-dropdown-toggle:hover {
    color: var(--color-accent);
}

.nav-dropdown-toggle svg {
    transition: transform 0.3s ease;
}

.nav-dropdown.active .nav-dropdown-toggle svg {
    transform: rotate(180deg);
}

.nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 16px);
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--color-dark);
    border: 1px solid #333;
    border-radius: 12px;
    padding: 8px;
    min-width: 160px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    z-index: 1000;
}

.nav-dropdown.active .nav-dropdown-menu {
    opacity: 1;
    visibility: visible;
}

.nav-dropdown-menu a {
    display: block;
    padding: 12px 16px;
    color: var(--color-text);
    text-decoration: none;
    font-size: 15px;
    border-radius: 8px;
    transition: background-color 0.2s ease, color 0.2s ease;
}

.nav-dropdown-menu a:hover {
    background-color: rgba(211, 233, 122, 0.1);
    color: var(--color-accent);
}

.mobile-menu-toggle {
    display: none;
    flex-direction: column;
    gap: 8px;
    cursor: pointer;
}

.mobile-menu-toggle span {
    width: 32px;
    height: 2px;
    background-color: var(--color-text);
    transition: all 0.3s ease;
}

/* Hero Section */
.hero {
    display: grid;
    grid-template-columns: 1fr 480px;
    gap: 60px;
    padding: 80px 108px;
    min-height: 75vh;
    align-items: center;
}

.hero-text h1 {
    font-family: var(--font-heading);
    font-size: 88px;
    line-height: 1.1;
    letter-spacing: -0.88px;
    color: var(--color-text);
    margin-bottom: 24px;
}

.hero-subtitle {
    font-size: 18px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin-bottom: 24px;
}

.hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: var(--accent);
    border: 1px solid transparent;
    padding: 10px 20px;
    border-radius: 24px;
    margin-bottom: 40px;
    color: var(--on-accent);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.3px;
}

.hero-badge svg {
    color: var(--on-accent);
}

.hero-actions {
    display: flex;
    align-items: center;
    gap: 16px;
}

.btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background-color: var(--accent);
    color: var(--on-accent);
    padding: 16px 32px;
    border-radius: 27px;
    border: none;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.5px;
    transition: transform 0.3s ease, background-color 0.3s ease;
    cursor: pointer;
}

.btn-primary:hover {
    background-color: var(--accent-hover);
    transform: translateY(-2px);
}

.hero-image {
    width: 480px;
    height: 560px;
    background-color: var(--paper-2);
    border-radius: 16px;
    overflow: hidden;
}

.hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
}

/* Sectors Section */
.sectors-section {
    padding: 120px 108px;
    background-color: var(--color-bg);
}

.sectors-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
}

.sector-card {
    background-color: var(--card);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 32px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: var(--shadow-card);
    transition: border-color 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
    position: relative;
}

.sector-card:hover {
    border-color: var(--accent-deep);
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
}

.sector-card--featured {
    border-color: rgba(211, 233, 122, 0.3);
    background: linear-gradient(135deg, var(--color-dark) 0%, rgba(211, 233, 122, 0.05) 100%);
}

.sector-card-icon {
    color: var(--accent-deep);
    margin-bottom: 4px;
}

.sector-card h3 {
    font-family: var(--font-heading);
    font-size: 28px;
    letter-spacing: -0.28px;
    color: var(--color-text);
    line-height: 1.1;
}

.sector-card p {
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-text-muted);
}

.sector-card-badge {
    display: inline-block;
    background-color: rgba(211, 233, 122, 0.1);
    color: var(--color-accent);
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    width: fit-content;
}

.sectors-cta {
    text-align: center;
    margin-top: 48px;
}

/* Our Process Section */
/* Page rhythm: paper -> paper-2 -> paper -> paper-2 -> paper -> lime -> ink.
   Tones alternate on every boundary, so no two neighbours share a background
   and the 1px hairlines that used to stand in for an edge are gone. The body
   stays in one tonal family; inversion is saved for the closing CTA and
   footer, so going dark keeps meaning "you've reached the end". */
.our-process-section {
    padding: 120px 108px;
    background-color: var(--color-surface);
}

.process-header {
    margin-bottom: 80px;
    max-width: 800px;
}

.process-kicker {
    display: block;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent-deep);
    margin-bottom: 12px;
}

.process-header h2 {
    font-family: var(--font-heading);
    font-size: 76px;
    letter-spacing: -0.76px;
    color: var(--color-text);
    margin-bottom: 24px;
    line-height: 1;
}

.process-header p {
    font-size: 20px;
    color: var(--color-text-muted);
}

.process-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    align-items: stretch;
}

.process-card {
    position: relative;
    background-color: var(--card);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 40px;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-card);
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
}

.process-card-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background-color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--on-accent);
    margin-bottom: 20px;
}

.process-card-badge {
    position: absolute;
    top: 24px;
    right: 24px;
    min-width: 32px;
    height: 32px;
    padding: 0 8px;
    border-radius: 16px;
    background-color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    color: var(--on-accent);
}

.process-card:hover {
    transform: translateY(-8px);
    border-color: var(--accent-deep);
    box-shadow: var(--shadow-card-hover);
}

.card-content h3 {
    font-family: var(--font-heading);
    font-size: 32px;
    letter-spacing: -0.32px;
    color: var(--color-text);
    margin-bottom: 16px;
}

.card-content p {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text-muted);
}

.process-tagline {
    color: #6a8b1d;
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 20px;
}

.process-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.process-bullets li {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-text-muted);
    padding-left: 20px;
    position: relative;
}

.process-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--accent-deep);
}

@media (max-width: 1024px) {
    .process-grid {
        grid-template-columns: 1fr;
        gap: 24px;
    }

    .process-card {
        min-height: auto;
    }
}

/* Case Study Section */
.case-study-section {
    padding: 120px 108px;
    border-top: 1px solid #333;
    background: linear-gradient(135deg, #0d0d0d 0%, #1a1a1a 100%);
    position: relative;
}

.case-study-badge {
    display: inline-block;
    background-color: rgba(211, 233, 122, 0.1);
    color: var(--color-accent);
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 40px;
}

.case-study-content {
    display: grid;
    grid-template-columns: 1fr 500px;
    gap: 80px;
    align-items: center;
}

.case-study-text h2 {
    font-family: var(--font-heading);
    font-size: 56px;
    letter-spacing: -0.56px;
    color: var(--color-text);
    margin-bottom: 24px;
    line-height: 1.1;
}

.case-study-intro {
    font-size: 18px;
    line-height: 1.7;
    color: var(--color-text);
    opacity: 0.9;
    margin-bottom: 48px;
}

.case-study-intro strong {
    color: var(--color-accent);
    font-weight: 600;
}

.case-study-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-bottom: 48px;
}

.metric {
    text-align: center;
    padding: 24px;
    background-color: rgba(211, 233, 122, 0.05);
    border: 1px solid rgba(211, 233, 122, 0.2);
    border-radius: 12px;
    transition: all 0.3s ease;
}

.metric:hover {
    background-color: rgba(211, 233, 122, 0.1);
    border-color: var(--color-accent);
    transform: translateY(-4px);
}

.metric-number {
    font-family: var(--font-heading);
    font-size: 48px;
    color: var(--color-accent);
    margin-bottom: 8px;
    line-height: 1;
}

.metric-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.metric-desc {
    font-size: 13px;
    color: var(--color-text);
    opacity: 0.7;
    line-height: 1.4;
}

.case-study-quote {
    background-color: rgba(211, 233, 122, 0.05);
    border-left: 4px solid var(--color-accent);
    padding: 32px;
    border-radius: 12px;
    margin-bottom: 32px;
}

.case-study-quote svg {
    color: var(--color-accent);
    margin-bottom: 16px;
}

.case-study-quote blockquote {
    font-size: 18px;
    line-height: 1.6;
    color: var(--color-text);
    font-style: italic;
    margin-bottom: 16px;
}

.case-study-quote cite {
    font-style: normal;
    font-size: 14px;
    color: var(--color-text);
    opacity: 0.8;
}

.case-study-quote cite strong {
    display: block;
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 4px;
    opacity: 1;
}

.case-study-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    font-size: 16px;
    transition: gap 0.3s ease;
}

.case-study-link:hover {
    gap: 12px;
}

.chatgpt-mockup {
    background-color: #1a1a1a;
    border: 2px solid #333;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
}

.mockup-header {
    background-color: #222;
    padding: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid #333;
}

.mockup-dots {
    display: flex;
    gap: 6px;
}

.mockup-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: #444;
}

.mockup-dots span:nth-child(1) {
    background-color: #ff5f56;
}

.mockup-dots span:nth-child(2) {
    background-color: #ffbd2e;
}

.mockup-dots span:nth-child(3) {
    background-color: #27c93f;
}

.mockup-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
}

.mockup-content {
    padding: 24px;
}

.chat-message {
    margin-bottom: 20px;
    padding: 16px;
    border-radius: 12px;
    line-height: 1.6;
}

.chat-message.user {
    background-color: rgba(211, 233, 122, 0.1);
    border: 1px solid rgba(211, 233, 122, 0.3);
}

.chat-message.user p {
    color: var(--color-text);
    font-size: 15px;
    margin: 0;
}

.chat-message.assistant {
    background-color: #222;
    border: 1px solid #333;
    position: relative;
}

.chat-message.assistant p {
    color: var(--color-text);
    font-size: 15px;
    margin: 0;
}

.rank-badge {
    display: inline-block;
    background-color: var(--color-accent);
    color: var(--on-accent);
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 8px;
}

.testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
}

.testimonial-card:hover {
    border-color: var(--color-accent);
}

.testimonial-tag {
    display: inline-block;
    background-color: rgba(211, 233, 122, 0.1);
    color: var(--color-accent);
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    align-self: flex-start;
}

.testimonial-text {
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-text);
    opacity: 0.9;
    font-style: italic;
}

.testimonial-author {
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid #333;
}

.author-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 4px;
}

.author-title {
    font-size: 13px;
    color: var(--color-text);
    opacity: 0.6;
}

/* Featured Projects - keeping for projects page */
.featured-projects {
    padding: 80px 108px;
    border-top: 1px solid #333;
}

.section-header {
    margin-bottom: 80px;
}

.section-header h2 {
    font-family: var(--font-heading);
    font-size: 76px;
    letter-spacing: -0.76px;
    color: var(--color-text);
    margin-bottom: 24px;
    line-height: 1;
}

.section-header p {
    font-size: 18px;
    max-width: 600px;
}

.projects-grid {
    display: flex;
    flex-direction: column;
    gap: 120px;
}

.project {
    display: grid;
    grid-template-columns: 600px 1fr;
    gap: 48px;
    align-items: center;
}

.project-reverse {
    direction: rtl;
}

.project-reverse > * {
    direction: ltr;
}

.project-image {
    position: relative;
    width: 600px;
    height: 600px;
    background-color: var(--color-dark);
    border-radius: 16px;
    overflow: hidden;
}

.project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.project-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background-color: rgba(0, 0, 0, 0.7);
    color: var(--color-text);
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 500;
}

.project-content {
    padding: 60px 0;
}

.project-content a {
    text-decoration: none;
    color: inherit;
}

.project-content h3 {
    font-size: 45px;
    line-height: 1.2;
    margin-bottom: 24px;
    color: var(--color-text);
    transition: color 0.3s ease;
}

.project-content a:hover h3 {
    color: var(--color-accent);
}

.project-image {
    display: block;
    text-decoration: none;
}

.project-content > p {
    font-size: 16px;
    line-height: 1.7;
    margin-bottom: 32px;
    color: var(--color-text);
}

.project-info {
    margin-bottom: 32px;
}

.project-info h4 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 16px;
    color: var(--color-text);
}

.info-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.info-item {
    display: flex;
    justify-content: space-between;
    padding: 16px 0;
    border-bottom: 1px solid #333;
}

.info-label {
    font-size: 16px;
    color: var(--color-text);
}

.info-value {
    font-size: 16px;
    font-weight: 500;
    color: var(--color-text);
}

.project-links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
}

.project-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-text);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: 4px;
    transition: color 0.3s ease;
}

.project-link:hover {
    color: var(--color-accent);
}

.project-link svg {
    width: 20px;
    height: 20px;
}

/* About Section */
.about-section {
    padding: 120px 108px;
    background-color: var(--color-bg);
}

.about-section h2 {
    font-family: var(--font-heading);
    font-size: 91px;
    letter-spacing: -0.91px;
    margin-bottom: 40px;
}

.about-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
}

.about-intro h3 {
    font-size: 45px;
    line-height: 1.2;
    color: var(--color-text);
}

.about-description p {
    font-size: 16px;
    line-height: 1.7;
    margin-bottom: 24px;
}

.text-link {
    display: inline-block;
    color: var(--accent-deep);
    text-decoration: none;
    font-size: 16px;
    font-weight: 600;
    border-bottom: 2px solid var(--accent-deep);
    padding-bottom: 4px;
    transition: color 0.3s ease, border-color 0.3s ease;
}

.text-link:hover {
    color: var(--accent-deep-hover);
    border-bottom-color: var(--accent-deep-hover);
}

/* Contact Section */
.contact-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    padding: 80px 108px;
    border-top: 1px solid #333;
}

.contact-left h2 {
    font-family: var(--font-heading);
    font-size: 76px;
    letter-spacing: -0.76px;
    margin-bottom: 32px;
}

.contact-details {
    margin-bottom: 32px;
}

.contact-details p {
    font-size: 18px;
    line-height: 1.5;
    margin-bottom: 8px;
}

.contact-details a {
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent);
    transition: color 0.3s ease;
}

.contact-details a:hover {
    color: var(--color-accent);
}

.social-links {
    display: flex;
    gap: 24px;
    margin-bottom: 120px;
}

.social-links a {
    color: var(--color-text);
    transition: color 0.3s ease;
}

.social-links a:hover {
    color: var(--color-accent);
}

.copyright {
    font-size: 16px;
    color: var(--color-text);
    opacity: 0.6;
}

/* Simple Contact Section */
.contact-section-simple {
    padding: 0;
    margin: 80px 108px;
    position: relative;
    overflow: hidden;
}

.contact-container {
    background: var(--accent);
    border: none;
    border-radius: 32px;
    padding: 120px 80px;
    position: relative;
    overflow: hidden;
}

.cta-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
}

.contact-section-simple h2 {
    font-family: var(--font-heading);
    font-size: 72px;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -1.5px;
    margin-bottom: 32px;
    color: var(--ink);
}

.cta-subtext {
    font-size: 18px;
    line-height: 1.6;
    margin-bottom: 48px;
    color: #2a2a24;
    max-width: 600px;
}

.cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--ink);
    color: var(--paper);
    padding: 18px 48px;
    border-radius: 27px;
    border: none;
    font-weight: 600;
    font-size: 16px;
    letter-spacing: 0.3px;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
    font-family: var(--font-primary);
    text-decoration: none;
}

.cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(26, 26, 26, 0.25);
    background-color: #000;
}

.cta-background-text {
    position: absolute;
    right: 80px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 400px;
    font-weight: 400;
    color: rgba(26, 26, 26, 0.06);
    line-height: 1;
    font-family: var(--font-heading);
    pointer-events: none;
    z-index: 1;
}

.contact-label {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-accent);
    font-weight: 600;
}

.contact-value {
    font-size: 18px;
    color: var(--color-text);
    font-weight: 500;
}

/* Contact Form */
.contact-form {
    padding-top: 0;
}

.form-group {
    margin-bottom: 24px;
}

.form-group label {
    display: block;
    font-size: 16px;
    margin-bottom: 12px;
    color: var(--color-text);
}

.form-group input,
.form-group textarea {
    width: 100%;
    background-color: transparent;
    border: none;
    border-bottom: 1px solid #333;
    padding: 16px;
    font-size: 16px;
    color: var(--color-text);
    font-family: var(--font-primary);
    transition: border-color 0.3s ease;
}

.form-group input:focus,
.form-group textarea:focus {
    outline: none;
    border-bottom-color: var(--color-accent);
}

.form-group textarea {
    resize: vertical;
}

.btn-submit {
    background-color: var(--color-accent);
    color: var(--on-accent);
    padding: 16px 48px;
    border: none;
    border-radius: 27px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: transform 0.3s ease, background-color 0.3s ease;
}

.btn-submit:hover {
    background-color: #c5db6f;
    transform: translateY(-2px);
}

.btn-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
}

/* Form Success Message */
.form-success {
    text-align: center;
    padding: 60px 40px;
    background-color: var(--color-dark);
    border: 1px solid var(--color-accent);
    border-radius: 16px;
    animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.success-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 24px;
    background-color: var(--color-accent);
    color: var(--on-accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
    font-weight: bold;
    animation: scaleIn 0.5s ease 0.2s both;
}

@keyframes scaleIn {
    from {
        transform: scale(0);
    }
    to {
        transform: scale(1);
    }
}

.form-success h3 {
    font-family: var(--font-heading);
    font-size: 36px;
    color: var(--color-accent);
    margin-bottom: 12px;
    letter-spacing: -0.36px;
}

.form-success p {
    font-size: 16px;
    color: var(--color-text);
    opacity: 0.9;
}

/* Responsive Design */
@media (max-width: 1024px) {
    .navigation {
        padding: 24px 32px;
    }

    .hero {
        grid-template-columns: 1fr;
        padding: 60px 32px;
    }

    .hero-image {
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
    }

    .sectors-section {
        padding: 60px 32px;
    }

    .sectors-layout {
        grid-template-columns: 1fr;
    }

    .sectors-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .our-process-section {
        padding: 80px 32px;
    }

    .our-process-section h2 {
        font-size: 56px;
        margin-bottom: 80px;
    }

    .process-steps {
        gap: 80px;
    }

    .process-step {
        grid-template-columns: 1fr;
        gap: 40px;
    }

    .step-number {
        font-size: 80px;
        top: -30px;
        left: -10px;
    }

    .step-content {
        padding: 20px 0;
    }

    .step-content h3 {
        font-size: 40px;
    }

    .step-content p {
        font-size: 17px;
        max-width: 100%;
    }

    .services-section {
        padding: 60px 32px;
    }

    .services-grid-primary {
        grid-template-columns: 1fr;
        gap: 32px;
    }

    .service-card-primary {
        padding: 40px 32px;
    }

    .service-card-primary h3 {
        font-size: 36px;
    }

    .service-intro {
        font-size: 16px;
    }

    .benefit-item {
        font-size: 14px;
    }

    .service-card-secondary {
        padding: 32px;
    }

    .service-card-secondary h3 {
        font-size: 24px;
    }

    .featured-projects {
        padding: 60px 32px;
    }

    .project {
        grid-template-columns: 1fr;
        gap: 32px;
    }

    .project-image {
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
    }

    .about-section {
        padding: 60px 32px;
    }

    .about-content {
        grid-template-columns: 1fr;
        gap: 40px;
    }

    .contact-section {
        grid-template-columns: 1fr;
        padding: 60px 32px;
    }
}

@media (max-width: 768px) {
    .navigation {
        padding: 20px 16px;
    }

    .logo {
        font-size: 28px;
    }

    .nav-links {
        position: fixed;
        top: 76px;
        right: -100%;
        width: 100%;
        height: calc(100vh - 76px);
        background-color: var(--color-bg);
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding: 40px 0;
        transition: right 0.3s ease;
        border-top: 1px solid var(--border);
    }

    .nav-links.active {
        right: 0;
    }

    .nav-links a {
        font-size: 24px;
    }

    .nav-dropdown-toggle {
        font-size: 24px;
    }

    .nav-dropdown-menu {
        position: static;
        transform: none;
        margin-top: 16px;
        border: none;
        background-color: transparent;
        padding: 0;
    }

    .nav-dropdown.active .nav-dropdown-menu {
        display: block;
    }

    .nav-dropdown-menu:not(.active) {
        display: none;
    }

    .nav-dropdown-menu a {
        font-size: 20px;
        padding: 12px 0;
    }

    .mobile-menu-toggle {
        display: flex;
    }

