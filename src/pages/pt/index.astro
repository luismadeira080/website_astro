---
import SEO from "../../components/SEO.astro";
import Schema from "../../components/Schema.astro";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";
import Footer from "../../components/Footer.astro";
---

<!doctype html>
<html lang="pt">
    <head>
        <!-- Google Tag Manager -->
        <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-WHTQCRZ4');</script>
        <!-- End Google Tag Manager -->
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="/favicon-32x32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href="/favicon-16x16.png"
        />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/apple-touch-icon.png"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600&display=swap"
            rel="stylesheet"
        />

        <!-- SEO Meta Tags -->
        <SEO
            title="Luís Madeira - O Seu Parceiro Contínuo de IA | Processos Fiáveis para PMEs"
            description="Parceiro contínuo de IA para PMEs. Mapeio o seu negócio para as maiores oportunidades de ROI e construo processos fiáveis e determinísticos que entregam resultados consistentes e auditáveis."
            locale="pt"
        />

        <!-- Structured Data -->
        <Schema type="Organization" />
        <Schema type="LocalBusiness" />
    </head>
    <body>
        <!-- Google Tag Manager (noscript) -->
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WHTQCRZ4"
        height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
        <!-- End Google Tag Manager (noscript) -->
        <!-- Navigation -->
        <nav class="navigation">
            <a href="/pt" class="logo">luís madeira</a>
            <div class="nav-links">
                <a href="/pt/consultoria">Serviços</a>
                <a href="/pt/projetos">Projetos</a>
                <a href="#about">Sobre</a>
                <a href="#contact">Contacto</a>
                <LanguageSwitcher currentPath="/pt/" />
            </div>
            <div class="mobile-menu-toggle">
                <span></span>
                <span></span>
            </div>
        </nav>

        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-content">
                <div class="hero-text">
                    <h1>LUÍS MADEIRA</h1>
                    <p class="hero-subtitle">
                        O seu parceiro contínuo de IA. Mapeio o seu negócio para identificar as maiores oportunidades de ROI, depois construo processos fiáveis e auditáveis que entregam resultados consistentes.
                    </p>
                    <div class="hero-badge">
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"
                                fill="currentColor"
                            />
                        </svg>
                        <span>Parceiro Contínuo de IA</span>
                    </div>
                </div>
                <div class="hero-actions">
                    <a href="#contact" class="btn-primary"
                        >Começar Projeto</a
                    >
                    <a
                        href="https://www.linkedin.com/in/lumadeira"
                        class="social-icon"
                        target="_blank"
                        aria-label="LinkedIn"
                    >
                        <svg
                            width="26"
                            height="26"
                            viewBox="0 0 24 24"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                d="M6.94 5.00002C6.93974 5.53046 6.72877 6.03906 6.35351 6.41394C5.97825 6.78883 5.46944 6.99929 4.939 6.99902C4.40857 6.99876 3.89997 6.78779 3.52508 6.41253C3.1502 6.03727 2.93974 5.52846 2.94 4.99802C2.94027 4.46759 3.15124 3.95899 3.5265 3.5841C3.90176 3.20922 4.41057 2.99876 4.941 2.99902C5.47144 2.99929 5.98004 3.21026 6.35492 3.58552C6.72981 3.96078 6.94027 4.46959 6.94 5.00002ZM7 8.48002H3V21H7V8.48002ZM13.32 8.48002H9.34V21H13.28V14.43C13.28 10.77 18.05 10.43 18.05 14.43V21H22V13.07C22 6.90002 14.94 7.13002 13.28 10.16L13.32 8.48002Z"
                                fill="currentColor"></path>
                        </svg>
                    </a>
                </div>
            </div>
            <div class="hero-image">
                <img src="/profile.jpeg" alt="Luís Madeira" />
            </div>
        </section>

        <!-- Sectors Section -->
        <section class="sectors-section">
            <div class="section-header">
                <h2>Setores Onde Atuo</h2>
                <p>Automação com IA adaptada ao seu setor.</p>
            </div>

            <div class="sectors-grid">
                <a href="/pt/projetos#ecommerce" class="sector-card">
                    <div class="sector-card-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                        </svg>
                    </div>
                    <h3>E-Commerce</h3>
                    <p>Stock, margens e rentabilidade sob controlo</p>

                </a>

                <a href="/pt/projetos#vendas" class="sector-card">
                    <div class="sector-card-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                    </div>
                    <h3>Vendas & Leads</h3>
                    <p>Resposta rápida, pipeline visível, CRM atualizado</p>
                </a>

                <a href="/pt/projetos#operacoes" class="sector-card">
                    <div class="sector-card-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="3"/>
                            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                        </svg>
                    </div>
                    <h3>Operações</h3>
                    <p>Relatórios e documentos que se tratam sozinhos</p>
                </a>


            </div>

            <div class="sectors-cta">
                <a href="/pt/projetos" class="text-link">VER TODOS OS PROJETOS</a>
            </div>
        </section>

        <!-- My Process Section -->
        <section class="our-process-section">
            <div class="process-header">
                <h2>COMO TRABALHO</h2>
                <p>Uma abordagem metódica e de baixo risco que começa por perceber o seu negócio — não por saltar direto para ferramentas.</p>
            </div>

            <div class="process-grid">
                <div class="process-card">
                    <div class="card-number">01</div>
                    <div class="card-content">
                        <h3>Descobrir & Diagnosticar</h3>
                        <p class="process-tagline">Perceber primeiro, automatizar depois.</p>
                        <ul class="process-bullets">
                            <li>Aprendo como o seu negócio realmente funciona: objetivos, restrições, handoffs, e como é uma 'vitória'.</li>
                            <li>Mapeio o seu stack tecnológico e onde vivem os dados: CRMs, inboxes, spreadsheets, ferramentas internas.</li>
                            <li>Audito processos para encontrar bottlenecks reais e decidir o que deve e não deve ser automatizado.</li>
                        </ul>
                    </div>
                </div>

                <div class="process-card">
                    <div class="card-number">02</div>
                    <div class="card-content">
                        <h3>Desenhar, Construir & Validar</h3>
                        <p class="process-tagline">Soluções fiáveis, testadas antes do lançamento.</p>
                        <ul class="process-bullets">
                            <li>Priorizo oportunidades de alto impacto e decido onde a IA ajuda, e onde não ajuda.</li>
                            <li>Desenho e construo workflows custom, testo abordagens diferentes com dados reais, e explico as minhas escolhas em linguagem simples.</li>
                            <li>Corro avaliações num ambiente real antes do rollout completo.</li>
                        </ul>
                    </div>
                </div>

                <div class="process-card">
                    <div class="card-number">03</div>
                    <div class="card-content">
                        <h3>Lançar, Monitorizar & Otimizar</h3>
                        <p class="process-tagline">Melhoria contínua, não um projeto pontual.</p>
                        <ul class="process-bullets">
                            <li>Lanço para produção com métricas de sucesso claras e salvaguardas.</li>
                            <li>Monitorizo performance, recolho feedback da sua equipa e clientes, e resolvo problemas rapidamente.</li>
                            <li>Refino continuamente prompts, lógica e modelos para que o sistema melhore à medida que o seu negócio evolui.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- About Me Section -->
        <section id="about" class="about-section">
            <h2>SOBRE MIM</h2>
            <div class="about-content">
                <div class="about-intro">
                    <h3>
                        Mapeio negócios para oportunidades de IA e construo processos em que pode confiar.
                    </h3>
                </div>
                <div class="about-description">
                    <p>
                        Natural do Porto, a fazer Mestrado em Gestão na IE
                        Business School. Ajudo PMEs portuguesas a trabalhar de
                        forma mais inteligente através de redesenho de workflows
                        e automação com IA.
                    </p>
                    <a href="/pt/sobre" class="text-link">MAIS SOBRE MIM</a>
                </div>
            </div>
        </section>

        <!-- Contact Section -->
        <section id="contact" class="contact-section-simple">
            <div class="contact-container">
                <div class="cta-content">
                    <h2>Desbloqueie o potencial escondido do seu negócio</h2>
                    <p class="cta-subtext">
                        Desbloqueie potencial inexplorado com soluções de IA
                        seguras, responsáveis e poderosas.
                    </p>
                    <a href="/pt/ai-contact" class="cta-button">Começar</a>
                </div>
                <div class="cta-background-text">LM</div>
            </div>
        </section>

        <script>
            // Mobile Menu Toggle
            const mobileMenuToggle = document.querySelector(
                ".mobile-menu-toggle",
            );
            const navLinks = document.querySelector(".nav-links");

            if (mobileMenuToggle) {
                mobileMenuToggle.addEventListener("click", () => {
                    mobileMenuToggle.classList.toggle("active");
                    navLinks.classList.toggle("active");
                });

                // Close menu when clicking on a link
                const links = navLinks.querySelectorAll("a");
                links.forEach((link) => {
                    link.addEventListener("click", () => {
                        mobileMenuToggle.classList.remove("active");
                        navLinks.classList.remove("active");
                    });
                });
            }

            // Smooth scrolling for anchor links
            document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
                anchor.addEventListener("click", function (e) {
                    e.preventDefault();
                    const target = document.querySelector(
                        this.getAttribute("href"),
                    );
                    if (target) {
                        target.scrollIntoView({
                            behavior: "smooth",
                            block: "start",
                        });
                    }
                });
            });

            // Add scroll effect to navigation
            let lastScroll = 0;
            const nav = document.querySelector(".navigation");

            window.addEventListener("scroll", () => {
                const currentScroll = window.pageYOffset;

                if (currentScroll > lastScroll && currentScroll > 100) {
                    nav.style.transform = "translateY(-100%)";
                } else {
                    nav.style.transform = "translateY(0)";
                }

                lastScroll = currentScroll;
            });

        </script>

        <Footer locale="pt" />
    </body>
</html>

<style>
    /* Reset & Base Styles */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --color-bg: #0d0d0d;
        --color-text: #c7c7c7;
        --color-accent: #d3e97a;
        --color-dark: #1a1a1a;
        --font-primary: "Inter", sans-serif;
        --font-heading: "Bebas Neue", sans-serif;
    }

    body {
        font-family: var(--font-primary);
        background-color: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        overflow-x: hidden;
    }

    /* Navigation */
    .navigation {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 60px;
        position: sticky;
        top: 0;
        background-color: var(--color-bg);
        z-index: 1000;
        transition: transform 0.3s ease;
    }

    .logo {
        font-family: var(--font-heading);
        font-size: 32px;
        letter-spacing: -0.32px;
        color: var(--color-text);
    }

    .nav-links {
        display: flex;
        gap: 32px;
    }

    .nav-links a {
        color: var(--color-text);
        text-decoration: none;
        font-size: 16px;
        font-weight: 500;
        letter-spacing: -0.48px;
        transition: color 0.3s ease;
    }

    .nav-links a:hover {
        color: var(--color-accent);
    }

    /* Dropdown Navigation */
    .nav-dropdown {
        position: relative;
    }

    .nav-dropdown-toggle {
        display: flex;
        align-items: center;
        gap: 6px;
        background: none;
        border: none;
        color: var(--color-text);
        font-size: 16px;
        font-weight: 500;
        letter-spacing: -0.48px;
        cursor: pointer;
        padding: 0;
        font-family: var(--font-primary);
        transition: color 0.3s ease;
    }

    .nav-dropdown-toggle:hover {
        color: var(--color-accent);
    }

    .nav-dropdown-toggle svg {
        transition: transform 0.3s ease;
    }

    .nav-dropdown.active .nav-dropdown-toggle svg {
        transform: rotate(180deg);
    }

    .nav-dropdown-menu {
        position: absolute;
        top: calc(100% + 16px);
        left: 50%;
        transform: translateX(-50%);
        background-color: var(--color-dark);
        border: 1px solid #333;
        border-radius: 12px;
        padding: 8px;
        min-width: 160px;
        opacity: 0;
        visibility: hidden;
        transition:
            opacity 0.3s ease,
            visibility 0.3s ease;
        z-index: 1000;
    }

    .nav-dropdown.active .nav-dropdown-menu {
        opacity: 1;
        visibility: visible;
    }

    .nav-dropdown-menu a {
        display: block;
        padding: 12px 16px;
        color: var(--color-text);
        text-decoration: none;
        font-size: 15px;
        border-radius: 8px;
        transition:
            background-color 0.2s ease,
            color 0.2s ease;
    }

    .nav-dropdown-menu a:hover {
        background-color: rgba(211, 233, 122, 0.1);
        color: var(--color-accent);
    }

    .mobile-menu-toggle {
        display: none;
        flex-direction: column;
        gap: 8px;
        cursor: pointer;
    }

    .mobile-menu-toggle span {
        width: 32px;
        height: 2px;
        background-color: var(--color-text);
        transition: all 0.3s ease;
    }

    /* Hero Section */
    .hero {
        display: grid;
        grid-template-columns: 1fr 600px;
        gap: 60px;
        padding: 80px 108px;
        min-height: calc(100vh - 96px);
        align-items: center;
    }

    .hero-text h1 {
        font-family: var(--font-heading);
        font-size: 88px;
        line-height: 1.1;
        letter-spacing: -0.88px;
        color: var(--color-text);
        margin-bottom: 24px;
    }

    .hero-subtitle {
        font-size: 18px;
        line-height: 1.5;
        color: var(--color-text);
        margin-bottom: 24px;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background-color: rgba(211, 233, 122, 0.15);
        border: 1px solid var(--color-accent);
        padding: 10px 20px;
        border-radius: 24px;
        margin-bottom: 40px;
        color: var(--color-accent);
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.3px;
    }

    .hero-badge svg {
        color: var(--color-accent);
    }

    .hero-actions {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        background-color: var(--color-accent);
        color: var(--color-bg);
        padding: 16px 32px;
        border-radius: 27px;
        border: none;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        letter-spacing: 0.5px;
        transition:
            transform 0.3s ease,
            background-color 0.3s ease;
        cursor: pointer;
    }

    .btn-primary:hover {
        background-color: #c5db6f;
        transform: translateY(-2px);
    }

    .social-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 54px;
        height: 54px;
        border: 1px solid var(--color-text);
        border-radius: 50%;
        color: var(--color-text);
        transition: all 0.3s ease;
        background: transparent;
        cursor: pointer;
    }

    .social-icon:hover {
        background-color: var(--color-accent);
        border-color: var(--color-accent);
        color: var(--color-bg);
    }

    .hero-image {
        width: 600px;
        height: 700px;
        background-color: var(--color-text);
        border-radius: 16px;
        overflow: hidden;
    }

    .hero-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
    }

    /* Sectors Section */
    .sectors-section {
        padding: 80px 108px;
        border-top: 1px solid #333;
    }

    .sectors-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
        margin-bottom: 48px;
    }

    .sector-card {
        background-color: var(--color-dark);
        border: 1px solid #333;
        border-radius: 16px;
        padding: 32px;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        gap: 12px;
        transition: border-color 0.3s ease, transform 0.2s ease;
        position: relative;
    }

    .sector-card:hover {
        border-color: var(--color-accent);
        transform: translateY(-4px);
    }

    .sector-card--featured {
        border-color: rgba(211, 233, 122, 0.3);
        background: linear-gradient(135deg, var(--color-dark) 0%, rgba(211, 233, 122, 0.05) 100%);
    }

    .sector-card-icon {
        color: var(--color-accent);
        margin-bottom: 4px;
    }

    .sector-card h3 {
        font-family: var(--font-heading);
        font-size: 28px;
        letter-spacing: -0.28px;
        color: var(--color-text);
        line-height: 1.1;
    }

    .sector-card p {
        font-size: 14px;
        line-height: 1.5;
        color: var(--color-text);
        opacity: 0.7;
    }

    .sector-card-badge {
        display: inline-block;
        background-color: rgba(211, 233, 122, 0.1);
        color: var(--color-accent);
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        width: fit-content;
    }

    .sectors-cta {
        text-align: center;
    }

    /* Our Process Section */
    .our-process-section {
        padding: 120px 108px;
        border-top: 1px solid #333;
        background-color: var(--color-bg);
    }

    .process-header {
        margin-bottom: 80px;
        max-width: 800px;
    }

    .process-header h2 {
        font-family: var(--font-heading);
        font-size: 76px;
        letter-spacing: -0.76px;
        color: var(--color-text);
        margin-bottom: 24px;
        line-height: 1;
    }

    .process-header p {
        font-size: 20px;
        color: var(--color-text);
        opacity: 0.8;
    }

    .process-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 40px;
        align-items: start;
    }

    .process-card {
        background-color: var(--color-dark);
        border: 1px solid #333;
        border-radius: 16px;
        padding: 40px;
        display: flex;
        flex-direction: column;
        min-height: 320px;
        transition:
            transform 0.3s ease,
            border-color 0.3s ease;
    }

    .process-card:hover {
        transform: translateY(-8px);
        border-color: var(--color-accent);
    }

    .card-number {
        font-family: var(--font-heading);
        font-size: 64px;
        color: var(--color-accent);
        opacity: 0.4;
        line-height: 1;
        margin-bottom: 32px;
    }

    .process-card:hover .card-number {
        opacity: 1;
    }

    .card-content h3 {
        font-family: var(--font-heading);
        font-size: 32px;
        letter-spacing: -0.32px;
        color: var(--color-text);
        margin-bottom: 16px;
    }

    .card-content p {
        font-size: 16px;
        line-height: 1.6;
        color: var(--color-text);
        opacity: 0.8;
    }

    .process-tagline {
        color: var(--color-accent);
        font-size: 15px;
        font-weight: 500;
        opacity: 1;
        margin-bottom: 20px;
    }

    .process-bullets {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .process-bullets li {
        font-size: 15px;
        line-height: 1.6;
        color: var(--color-text);
        opacity: 0.8;
        padding-left: 20px;
        position: relative;
    }

    .process-bullets li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 10px;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background-color: var(--color-accent);
    }

    @media (max-width: 1024px) {
        .process-grid {
            grid-template-columns: 1fr;
            gap: 24px;
        }

        .process-card {
            min-height: auto;
        }
    }

    /* Case Study Section */
    .case-study-section {
        padding: 120px 108px;
        border-top: 1px solid #333;
        background: linear-gradient(135deg, #0d0d0d 0%, #1a1a1a 100%);
        position: relative;
    }

    .case-study-badge {
        display: inline-block;
        background-color: rgba(211, 233, 122, 0.1);
        color: var(--color-accent);
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 40px;
    }

    .case-study-content {
        display: grid;
        grid-template-columns: 1fr 500px;
        gap: 80px;
        align-items: center;
    }

    .case-study-text h2 {
        font-family: var(--font-heading);
        font-size: 56px;
        letter-spacing: -0.56px;
        color: var(--color-text);
        margin-bottom: 24px;
        line-height: 1.1;
    }

    .case-study-intro {
        font-size: 18px;
        line-height: 1.7;
        color: var(--color-text);
        opacity: 0.9;
        margin-bottom: 48px;
    }

    .case-study-intro strong {
        color: var(--color-accent);
        font-weight: 600;
    }

    .case-study-metrics {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 32px;
        margin-bottom: 48px;
    }

    .metric {
        text-align: center;
        padding: 24px;
        background-color: rgba(211, 233, 122, 0.05);
        border: 1px solid rgba(211, 233, 122, 0.2);
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .metric:hover {
        background-color: rgba(211, 233, 122, 0.1);
        border-color: var(--color-accent);
        transform: translateY(-4px);
    }

    .metric-number {
        font-family: var(--font-heading);
        font-size: 48px;
        color: var(--color-accent);
        margin-bottom: 8px;
        line-height: 1;
    }

    .metric-label {
        font-size: 14px;
        font-weight: 600;
        color: var(--color-text);
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .metric-desc {
        font-size: 13px;
        color: var(--color-text);
        opacity: 0.7;
        line-height: 1.4;
    }

    .case-study-quote {
        background-color: rgba(211, 233, 122, 0.05);
        border-left: 4px solid var(--color-accent);
        padding: 32px;
        border-radius: 12px;
        margin-bottom: 32px;
    }

    .case-study-quote svg {
        color: var(--color-accent);
        margin-bottom: 16px;
    }

    .case-study-quote blockquote {
        font-size: 18px;
        line-height: 1.6;
        color: var(--color-text);
        font-style: italic;
        margin-bottom: 16px;
    }

    .case-study-quote cite {
        font-style: normal;
        font-size: 14px;
        color: var(--color-text);
        opacity: 0.8;
    }

    .case-study-quote cite strong {
        display: block;
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 4px;
        opacity: 1;
    }

    .case-study-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--color-accent);
        text-decoration: none;
        font-weight: 600;
        font-size: 16px;
        transition: gap 0.3s ease;
    }

    .case-study-link:hover {
        gap: 12px;
    }

    .chatgpt-mockup {
        background-color: #1a1a1a;
        border: 2px solid #333;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    }

    .mockup-header {
        background-color: #222;
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        border-bottom: 1px solid #333;
    }

    .mockup-dots {
        display: flex;
        gap: 6px;
    }

    .mockup-dots span {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: #444;
    }

    .mockup-dots span:nth-child(1) {
        background-color: #ff5f56;
    }

    .mockup-dots span:nth-child(2) {
        background-color: #ffbd2e;
    }

    .mockup-dots span:nth-child(3) {
        background-color: #27c93f;
    }

    .mockup-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--color-text);
    }

    .mockup-content {
        padding: 24px;
    }

    .chat-message {
        margin-bottom: 20px;
        padding: 16px;
        border-radius: 12px;
        line-height: 1.6;
    }

    .chat-message.user {
        background-color: rgba(211, 233, 122, 0.1);
        border: 1px solid rgba(211, 233, 122, 0.3);
    }

    .chat-message.user p {
        color: var(--color-text);
        font-size: 15px;
        margin: 0;
    }

    .chat-message.assistant {
        background-color: #222;
        border: 1px solid #333;
        position: relative;
    }

    .chat-message.assistant p {
        color: var(--color-text);
        font-size: 15px;
        margin: 0;
    }

    .rank-badge {
        display: inline-block;
        background-color: var(--color-accent);
        color: var(--color-bg);
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    /* Testimonials Section */
    .testimonials-section {
        padding: 80px 108px;
        border-top: 1px solid #333;
    }

    .testimonials-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 32px;
    }

    .testimonial-card {
        background-color: var(--color-dark);
        border: 1px solid #333;
        border-radius: 12px;
        padding: 32px;
        display: flex;
        flex-direction: column;
        gap: 20px;
        transition: border-color 0.3s ease;
    }

    .testimonial-card:hover {
        border-color: var(--color-accent);
    }

    .testimonial-tag {
        display: inline-block;
        background-color: rgba(211, 233, 122, 0.1);
        color: var(--color-accent);
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        align-self: flex-start;
    }

    .testimonial-text {
        font-size: 16px;
        line-height: 1.7;
        color: var(--color-text);
        opacity: 0.9;
        font-style: italic;
    }

    .testimonial-author {
        margin-top: auto;
        padding-top: 20px;
        border-top: 1px solid #333;
    }

    .author-name {
        font-size: 15px;
        font-weight: 600;
        color: var(--color-text);
        margin-bottom: 4px;
    }

    .author-title {
        font-size: 13px;
        color: var(--color-text);
        opacity: 0.6;
    }

    /* Featured Projects - keeping for projects page */
    .featured-projects {
        padding: 80px 108px;
        border-top: 1px solid #333;
    }

    .section-header {
        margin-bottom: 80px;
    }

    .section-header h2 {
        font-family: var(--font-heading);
        font-size: 76px;
        letter-spacing: -0.76px;
        color: var(--color-text);
        margin-bottom: 24px;
        line-height: 1;
    }

    .section-header p {
        font-size: 18px;
        max-width: 600px;
    }

    .projects-grid {
        display: flex;
        flex-direction: column;
        gap: 120px;
    }

    .project {
        display: grid;
        grid-template-columns: 600px 1fr;
        gap: 48px;
        align-items: center;
    }

    .project-reverse {
        direction: rtl;
    }

    .project-reverse > * {
        direction: ltr;
    }

    .project-image {
        position: relative;
        width: 600px;
        height: 600px;
        background-color: var(--color-dark);
        border-radius: 16px;
        overflow: hidden;
    }

    .project-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .project-badge {
        position: absolute;
        top: 16px;
        left: 16px;
        background-color: rgba(0, 0, 0, 0.7);
        color: var(--color-text);
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 500;
    }

    .project-content {
        padding: 60px 0;
    }

    .project-content a {
        text-decoration: none;
        color: inherit;
    }

    .project-content h3 {
        font-size: 45px;
        line-height: 1.2;
        margin-bottom: 24px;
        color: var(--color-text);
        transition: color 0.3s ease;
    }

    .project-content a:hover h3 {
        color: var(--color-accent);
    }

    .project-image {
        display: block;
        text-decoration: none;
    }

    .project-content > p {
        font-size: 16px;
        line-height: 1.7;
        margin-bottom: 32px;
        color: var(--color-text);
    }

    .project-info {
        margin-bottom: 32px;
    }

    .project-info h4 {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 16px;
        color: var(--color-text);
    }

    .info-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .info-item {
        display: flex;
        justify-content: space-between;
        padding: 16px 0;
        border-bottom: 1px solid #333;
    }

    .info-label {
        font-size: 16px;
        color: var(--color-text);
    }

    .info-value {
        font-size: 16px;
        font-weight: 500;
        color: var(--color-text);
    }

    .project-links {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
    }

    .project-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--color-text);
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.5px;
        border-bottom: 2px solid var(--color-accent);
        padding-bottom: 4px;
        transition: color 0.3s ease;
    }

    .project-link:hover {
        color: var(--color-accent);
    }

    .project-link svg {
        width: 20px;
        height: 20px;
    }

    /* About Section */
    .about-section {
        padding: 80px 108px;
        border-top: 1px solid #333;
    }

    .about-section h2 {
        font-family: var(--font-heading);
        font-size: 91px;
        letter-spacing: -0.91px;
        margin-bottom: 40px;
    }

    .about-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 72px;
    }

    .about-intro h3 {
        font-size: 45px;
        line-height: 1.2;
        color: var(--color-text);
    }

    .about-description p {
        font-size: 16px;
        line-height: 1.7;
        margin-bottom: 24px;
    }

    .text-link {
        display: inline-block;
        color: var(--color-text);
        text-decoration: none;
        font-size: 16px;
        font-weight: 600;
        border-bottom: 2px solid var(--color-accent);
        padding-bottom: 4px;
        transition: color 0.3s ease;
    }

    .text-link:hover {
        color: var(--color-accent);
    }

    /* Contact Section */
    .contact-section {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        padding: 80px 108px;
        border-top: 1px solid #333;
    }

    .contact-left h2 {
        font-family: var(--font-heading);
        font-size: 76px;
        letter-spacing: -0.76px;
        margin-bottom: 32px;
    }

    .contact-details {
        margin-bottom: 32px;
    }

    .contact-details p {
        font-size: 18px;
        line-height: 1.5;
        margin-bottom: 8px;
    }

    .contact-details a {
        color: var(--color-text);
        text-decoration: none;
        border-bottom: 1px solid var(--color-accent);
        transition: color 0.3s ease;
    }

    .contact-details a:hover {
        color: var(--color-accent);
    }

    .social-links {
        display: flex;
        gap: 24px;
        margin-bottom: 120px;
    }

    .social-links a {
        color: var(--color-text);
        transition: color 0.3s ease;
    }

    .social-links a:hover {
        color: var(--color-accent);
    }

    .copyright {
        font-size: 16px;
        color: var(--color-text);
        opacity: 0.6;
    }

    /* Simple Contact Section */
    .contact-section-simple {
        padding: 0;
        margin: 80px 108px;
        position: relative;
        overflow: hidden;
    }

    .contact-container {
        background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
        border: 2px solid var(--color-accent);
        border-radius: 32px;
        padding: 120px 80px;
        position: relative;
        overflow: hidden;
    }

    .cta-content {
        position: relative;
        z-index: 2;
        max-width: 700px;
    }

    .contact-section-simple h2 {
        font-family: var(--font-heading);
        font-size: 72px;
        font-weight: 700;
        line-height: 1.1;
        letter-spacing: -1.5px;
        margin-bottom: 32px;
        color: #ffffff;
    }

    .cta-subtext {
        font-size: 18px;
        line-height: 1.6;
        margin-bottom: 48px;
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
    }

    .cta-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background-color: var(--color-accent);
        color: var(--color-bg);
        padding: 18px 48px;
        border-radius: 12px;
        border: none;
        font-weight: 600;
        font-size: 16px;
        letter-spacing: 0.3px;
        cursor: pointer;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease,
            background-color 0.3s ease;
        font-family: var(--font-primary);
    }

    .cta-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(211, 233, 122, 0.4);
        background-color: #c5db6f;
    }

    .cta-background-text {
        position: absolute;
        right: 80px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 400px;
        font-weight: 900;
        color: rgba(211, 233, 122, 0.05);
        line-height: 1;
        font-family: var(--font-heading);
        pointer-events: none;
        z-index: 1;
    }

    .contact-label {
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--color-accent);
        font-weight: 600;
    }

    .contact-value {
        font-size: 18px;
        color: var(--color-text);
        font-weight: 500;
    }

    /* Contact Form */
    .contact-form {
        padding-top: 0;
    }

    .form-group {
        margin-bottom: 24px;
    }

    .form-group label {
        display: block;
        font-size: 16px;
        margin-bottom: 12px;
        color: var(--color-text);
    }

    .form-group input,
    .form-group textarea {
        width: 100%;
        background-color: transparent;
        border: none;
        border-bottom: 1px solid #333;
        padding: 16px;
        font-size: 16px;
        color: var(--color-text);
        font-family: var(--font-primary);
        transition: border-color 0.3s ease;
    }

    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-bottom-color: var(--color-accent);
    }

    .form-group textarea {
        resize: vertical;
    }

    .btn-submit {
        background-color: var(--color-accent);
        color: var(--color-bg);
        padding: 16px 48px;
        border: none;
        border-radius: 27px;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition:
            transform 0.3s ease,
            background-color 0.3s ease;
    }

    .btn-submit:hover {
        background-color: #c5db6f;
        transform: translateY(-2px);
    }

    .btn-submit:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        transform: none;
    }

    /* Form Success Message */
    .form-success {
        text-align: center;
        padding: 60px 40px;
        background-color: var(--color-dark);
        border: 1px solid var(--color-accent);
        border-radius: 16px;
        animation: fadeIn 0.5s ease;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .success-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 24px;
        background-color: var(--color-accent);
        color: var(--color-bg);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 48px;
        font-weight: bold;
        animation: scaleIn 0.5s ease 0.2s both;
    }

    @keyframes scaleIn {
        from {
            transform: scale(0);
        }
        to {
            transform: scale(1);
        }
    }

    .form-success h3 {
        font-family: var(--font-heading);
        font-size: 36px;
        color: var(--color-accent);
        margin-bottom: 12px;
        letter-spacing: -0.36px;
    }

    .form-success p {
        font-size: 16px;
        color: var(--color-text);
        opacity: 0.9;
    }

    /* Responsive Design */
    @media (max-width: 1024px) {
        .navigation {
            padding: 24px 32px;
        }

        .hero {
            grid-template-columns: 1fr;
            padding: 60px 32px;
        }

        .hero-image {
            width: 100%;
            max-width: 600px;
            margin: 0 auto;
        }

        .sectors-section {
            padding: 60px 32px;
        }

        .sectors-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .case-study-metrics {
            grid-template-columns: 1fr;
            gap: 24px;
        }

        .our-process-section {
            padding: 80px 32px;
        }

        .our-process-section h2 {
            font-size: 56px;
            margin-bottom: 80px;
        }

        .process-steps {
            gap: 80px;
        }

        .process-step {
            grid-template-columns: 1fr;
            gap: 40px;
        }

        .step-number {
            font-size: 80px;
            top: -30px;
            left: -10px;
        }

        .step-content {
            padding: 20px 0;
        }

        .step-content h3 {
            font-size: 40px;
        }

        .step-content p {
            font-size: 17px;
            max-width: 100%;
        }

        .services-section {
            padding: 60px 32px;
        }

        .services-grid-primary {
            grid-template-columns: 1fr;
            gap: 32px;
        }

        .service-card-primary {
            padding: 40px 32px;
        }

        .service-card-primary h3 {
            font-size: 36px;
        }

        .service-intro {
            font-size: 16px;
        }

        .benefit-item {
            font-size: 14px;
        }

        .service-card-secondary {
            padding: 32px;
        }

        .service-card-secondary h3 {
            font-size: 24px;
        }

        .featured-projects {
            padding: 60px 32px;
        }

        .project {
            grid-template-columns: 1fr;
            gap: 32px;
        }

        .project-image {
            width: 100%;
            max-width: 600px;
            margin: 0 auto;
        }

        .about-section {
            padding: 60px 32px;
        }

        .about-content {
            grid-template-columns: 1fr;
            gap: 40px;
        }

        .contact-section {
            grid-template-columns: 1fr;
            padding: 60px 32px;
        }
    }

    @media (max-width: 768px) {
        .navigation {
            padding: 20px 16px;
        }

        .logo {
            font-size: 28px;
        }

        .nav-links {
            position: fixed;
            top: 76px;
            right: -100%;
            width: 100%;
            height: calc(100vh - 76px);
            background-color: var(--color-bg);
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            padding: 40px 0;
            transition: right 0.3s ease;
            border-top: 1px solid #333;
        }

        .nav-links.active {
            right: 0;
        }

        .nav-links a {
            font-size: 24px;
        }

        .nav-dropdown-toggle {
            font-size: 24px;
        }

        .nav-dropdown-menu {
            position: static;
            transform: none;
            margin-top: 16px;
            border: none;
            background-color: transparent;
            padding: 0;
        }

        .nav-dropdown.active .nav-dropdown-menu {
            display: block;
        }

        .nav-dropdown-menu:not(.active) {
            display: none;
        }

        .nav-dropdown-menu a {
            font-size: 20px;
            padding: 12px 0;
        }

        .mobile-menu-toggle {
            display: flex;
        }

        .mobile-menu-toggle.active span:first-child {
            transform: rotate(45deg) translate(8px, 8px);
        }

        .mobile-menu-toggle.active span:last-child {
            transform: rotate(-45deg) translate(8px, -8px);
        }

        .hero {
            grid-template-columns: 1fr;
            padding: 40px 16px;
            min-height: auto;
            gap: 40px;
        }

        .hero-text h1 {
            font-size: 64px;
        }

        .hero-subtitle {
            font-size: 16px;
        }

        .hero-actions {
