---
import SEO from "../../components/SEO.astro";
import Schema from "../../components/Schema.astro";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";
import Footer from "../../components/Footer.astro";
import '../../styles/tokens.css';
---

<!doctype html>
<html lang="pt">
    <head>
        <!-- Google Tag Manager -->
        <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-WHTQCRZ4');</script>
        <!-- End Google Tag Manager -->
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="/favicon-32x32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href="/favicon-16x16.png"
        />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/apple-touch-icon.png"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />

        <!-- SEO Meta Tags -->
        <SEO
            title="Consultoria de IA"
            description="Parceiro contínuo de IA para PMEs. Mapeio onde a IA gera mais retorno, construo processos fiáveis e auditáveis, e evoluo consigo."
            locale="pt"
        />

        <!-- Structured Data -->
        <Schema type="Organization" />
    </head>
    <body>
        <!-- Google Tag Manager (noscript) -->
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WHTQCRZ4"
        height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
        <!-- End Google Tag Manager (noscript) -->
        <!-- Navigation -->
        <nav class="navigation">
            <a href="/pt" class="logo">luís madeira</a>
            <div class="nav-links">
                <a href="/pt/servicos">Serviços</a>
                <a href="/pt/sobre">Sobre</a>
                <a href="/pt/#contact">Contacto</a>
                <LanguageSwitcher currentPath="/pt/servicos" />
            </div>
            <div class="mobile-menu-toggle">
                <span></span>
                <span></span>
            </div>
        </nav>

        <!-- Hero Section -->
        <section class="page-hero">
            <div class="page-hero-content">
                <h1>SOLUÇÕES INTERNAS POTENCIADAS POR IA.</h1>
                <p class="page-hero-subtitle">
                    IA aplicada, construída à volta de como o seu negócio realmente funciona. Abaixo, a imagem completa: o que construo, e onde já está a correr.
                </p>
            </div>
        </section>

        <!-- Main Content -->
        <section class="content-section">
            <div class="content-wrapper">
                <div class="content-main">

                    <!-- Introdução da secção -->
                    <div class="catalog-group reveal">
                        <h2 class="catalog-group-title">O que construo</h2>
                        <p class="catalog-group-intro">Aplicadas a todas as áreas do seu negócio: marketing, finanças, RH, operações, em qualquer sítio onde haja trabalho. Abaixo, o que construo, e algumas áreas onde já está a correr.</p>
                    </div>

                    <!-- 01 · Process Mining & Discovery -->
                    <div class="area-block reveal" id="process-mining">
                        <div class="area-block-summary" role="button" tabindex="0" aria-expanded="false">
                            <span class="area-block-icon">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="3" width="6" height="6"/><rect x="15" y="15" width="6" height="6"/><path d="M9 6h6a3 3 0 0 1 3 3v6"/>
                                </svg>
                            </span>
                            <span class="area-block-pill">01</span>
                            <h2 class="area-block-title">Process Mining &amp; Discovery</h2>
                            <span class="area-block-chevron" aria-hidden="true">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9"/>
                                </svg>
                            </span>
                            <span class="area-block-teaser">Sabe que tempo e dinheiro vazam, mas não sabe exatamente onde.</span>
                        </div>
                        <div class="area-block-body"><div class="area-block-body-inner">
                            <p>Mapeio, com os seus dados, como o trabalho flui no seu negócio, e construo um heatmap de ineficiência e uma matriz valor-vs-esforço para priorizar o que corrigir primeiro.</p>
                            <p class="area-block-label">Resultados</p>
                            <ul class="area-checklist">
                                <li>Um mapa data-driven de como o trabalho realmente flui</li>
                                <li>Um heatmap de onde tempo e dinheiro vazam</li>
                                <li>Uma matriz valor-vs-esforço: os 20% de mudanças que dão 80% do impacto</li>
                            </ul>
                        </div>
                        </div>
                    </div>

                    <!-- 02 · Stock & Compras -->
                    <div class="area-block reveal" id="stock">
                        <div class="area-block-summary" role="button" tabindex="0" aria-expanded="false">
                            <span class="area-block-icon">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                                    <polyline points="3.29 7 12 12 20.71 7"/><line x1="12" y1="22" x2="12" y2="12"/>
                                </svg>
                            </span>
                            <span class="area-block-pill">02</span>
                            <h2 class="area-block-title">Stock &amp; Compras</h2>
                            <span class="area-block-chevron" aria-hidden="true">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9"/>
                                </svg>
                            </span>
                            <span class="area-block-teaser">Stock em folhas de cálculo que raramente coincidem, com compras dependentes de quem se lembra de verificar.</span>
                        </div>
                        <div class="area-block-body"><div class="area-block-body-inner">
                            <p>Construo um sistema de reposição sobre o seu ERP que lê movimento real, prevê procura, e repõe sozinho, reencaminhando perante disrupções.</p>
                            <p class="area-block-label">Resultados</p>
                            <ul class="area-checklist">
                                <li>Visão única e consolidada do stock, não múltiplas folhas</li>
                                <li>Previsão de procura baseada em vendas reais</li>
                                <li>Pontos de reposição automáticos, ligados ao ERP</li>
                            </ul>
                        </div>
                        </div>
                    </div>

                    <!-- 03 · Data & Integration Layer -->
                    <div class="area-block reveal" id="data-layer">
                        <div class="area-block-summary" role="button" tabindex="0" aria-expanded="false">
                            <span class="area-block-icon">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <ellipse cx="12" cy="5" r="9"/><path d="M3 5v14a9 9 0 0 0 18 0V5"/><path d="M3 12a9 9 0 0 0 18 0"/>
                                </svg>
                            </span>
                            <span class="area-block-pill">03</span>
                            <h2 class="area-block-title">Data &amp; Integration Layer</h2>
                            <span class="area-block-chevron" aria-hidden="true">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9"/>
                                </svg>
                            </span>
                            <span class="area-block-teaser">Os seus dados estão espalhados por folhas de cálculo, ERP, emails e PDFs, pelo que nada tem a imagem completa.</span>
                        </div>
                        <div class="area-block-body"><div class="area-block-body-inner">
                            <p>Ligo essas fontes numa fonte de verdade única, AI-ready e com contexto, para que as automações por cima percebam o seu negócio.</p>
                            <p class="area-block-label">Resultados</p>
                            <ul class="area-checklist">
                                <li>Fonte de verdade única entre folhas, ERP, email e documentos</li>
                                <li>Dados com contexto: as automações decidem com a imagem completa, não com fragmentos</li>
                                <li>Fundação AI-ready sobre a qual tudo o resto se constrói</li>
                            </ul>
                        </div>
                        </div>
                    </div>

                    <!-- 04 · Intelligent Document Processing -->
                    <div class="area-block reveal" id="idp">
                        <div class="area-block-summary" role="button" tabindex="0" aria-expanded="false">
                            <span class="area-block-icon">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><line x1="7" y1="12" x2="17" y2="12"/>
                                </svg>
                            </span>
                            <span class="area-block-pill">04</span>
                            <h2 class="area-block-title">Intelligent Document Processing</h2>
                            <span class="area-block-chevron" aria-hidden="true">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9"/>
                                </svg>
                            </span>
                            <span class="area-block-teaser">Faturas, contratos e recibos tratados à mão, um a um.</span>
                        </div>
                        <div class="area-block-body"><div class="area-block-body-inner">
                            <p>Configuro processamento que lê e extrai de documentos não estruturados com precisão quase humana, depois classifica e encaminha automaticamente.</p>
                            <p class="area-block-label">Resultados</p>
                            <ul class="area-checklist">
                                <li>Faturas, contratos e recibos lidos e extraídos automaticamente</li>
                                <li>Documentos classificados e encaminhados sem ordenação manual</li>
                                <li>Trilha de auditoria em cada extração</li>
                            </ul>
                        </div>
                        </div>
                    </div>

                    <!-- 05 · AI-Powered Dashboards -->
                    <div class="area-block reveal" id="dashboards">
                        <div class="area-block-summary" role="button" tabindex="0" aria-expanded="false">
                            <span class="area-block-icon">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/>
                                </svg>
                            </span>
                            <span class="area-block-pill">05</span>
                            <h2 class="area-block-title">AI-Powered Dashboards</h2>
                            <span class="area-block-chevron" aria-hidden="true">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9"/>
                                </svg>
                            </span>
                            <span class="area-block-teaser">Decisões sobre dados velhos e fragmentados, e a direção a perguntar pelos números.</span>
                        </div>
                        <div class="area-block-body"><div class="area-block-body-inner">
                            <p>Consolido todas as fontes em dashboards vivos, com analytics conversacional: pergunta ao negócio em linguagem natural e recebe respostas.</p>
                            <p class="area-block-label">Resultados</p>
                            <ul class="area-checklist">
                                <li>Dashboards em tempo real, sem esperar pelo fecho do mês</li>
                                <li>Analytics conversacional: perguntar em linguagem natural, receber respostas</li>
                                <li>Sinais preventivos, não um espelho retrovisor</li>
                            </ul>
                        </div>
                        </div>
                    </div>

                    <!-- 06 · Vendas & Previsões de Receita -->
                    <div class="area-block reveal" id="sales">
                        <div class="area-block-summary" role="button" tabindex="0" aria-expanded="false">
                            <span class="area-block-icon">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>
                                </svg>
                            </span>
                            <span class="area-block-pill">06</span>
                            <h2 class="area-block-title">Vendas &amp; Previsões de Receita</h2>
                            <span class="area-block-chevron" aria-hidden="true">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9"/>
                                </svg>
                            </span>
                            <span class="area-block-teaser">A receita é um palpite, o pipeline é uma sensação, e descobre-se tarde demais quais os deals que fecham.</span>
                        </div>
                        <div class="area-block-body"><div class="area-block-body-inner">
                            <p>Construo modelos preditivos sobre os seus dados de vendas: quais leads convertem, quais deals fecham e quando, e que receita esperar, para as decisões comerciais correrem sobre previsões.</p>
                            <p class="area-block-label">Resultados</p>
                            <ul class="area-checklist">
                                <li>Lead scoring: quais prospects têm mais probabilidade de converter</li>
                                <li>Previsão de deals e receita para as semanas e meses seguintes</li>
                                <li>Alertas de pipeline em risco, antes de escapar</li>
                            </ul>
                        </div>
                        </div>
                    </div>

                    <!-- 07 · Operações & Admin -->
                    <div class="area-block reveal" id="operations-admin">
                        <div class="area-block-summary" role="button" tabindex="0" aria-expanded="false">
                            <span class="area-block-icon">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/>
                                </svg>
                            </span>
                            <span class="area-block-pill">07</span>
                            <h2 class="area-block-title">Operações &amp; Admin</h2>
                            <span class="area-block-chevron" aria-hidden="true">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9"/>
                                </svg>
                            </span>
                            <span class="area-block-teaser">O trabalho estagna nos handoffs, o back-office acumula-se, e pedidos repetitivos enterram a equipa.</span>
                        </div>
                        <div class="area-block-body"><div class="area-block-body-inner">
                            <p>Ligo os sistemas que se passam trabalho entre si, automato o back-office documental e faço a triagem de pedidos repetitivos de apoio ao cliente, para que operações, admin e apoio corram como um processo de fundo silencioso.</p>
                            <p class="area-block-label">Resultados</p>
                            <ul class="area-checklist">
                                <li>Menos handoffs manuais entre pessoas e sistemas</li>
                                <li>Documentos de back-office processados e encaminhados automaticamente</li>
                                <li>Tickets repetitivos triados e respondidos de forma consistente</li>
                                <li>Onboarding e pedidos internos tratados sem perseguições</li>
                            </ul>
                        </div>
                        </div>
                    </div>

                    <!-- Capacitação em IA (oferta separada, destacada) -->
                    <div class="enablement-panel reveal">
                        <div class="enablement-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 10L12 5 2 10l10 5z"/>
                                <path d="M6 12v5c0 1.5 3 3 6 3s6-1.5 6-3v-5"/>
                            </svg>
                        </div>
                        <h2 class="enablement-title">Capacitação em IA para a sua equipa</h2>
                        <p class="enablement-lead">Para além de construir soluções, ajudo as suas pessoas a trabalhar mesmo com IA: workshops e sessões práticas, ajustados à forma como o seu negócio funciona, para a equipa ficar confiante e capaz, não apenas informada.</p>
                        <ul class="enablement-list">
                            <li>Workshops sobre onde a IA encaixa no trabalho do dia a dia</li>
                            <li>Sessões práticas em tarefas reais que a sua equipa já faz</li>
                            <li>Adoção prática, não teoria: ferramentas, prompts e hábitos que ficam</li>
                        </ul>
                        <a href="/pt/ai-contact" class="enablement-cta">Marcar um workshop</a>
                    </div>

                </div>

                <div class="content-sidebar">
                    <div class="sidebar-card reveal">
                        <h3>Duas formas de começar</h3>
                        <p>Um Diagnóstico Operacional se não tem a certeza de onde está a oportunidade, ou avançar diretamente para a construção se já sabe o que precisa. Adapto-me ao ponto em que o seu negócio está.</p>
                    </div>

                    <div class="sidebar-card cta-card reveal">
                        <h3>Vamos falar</h3>
                        <p>Diga-me o que o está a travar. Digo-lhe o que posso fazer.</p>
                        <a href="/pt/ai-contact" class="sidebar-cta">Entrar em contacto</a>
                    </div>
                </div>
            </div>
        </section>

        <script>
            // Mobile Menu Toggle
            const mobileMenuToggle = document.querySelector(
                ".mobile-menu-toggle",
            );
            const navLinks = document.querySelector(".nav-links");

            if (mobileMenuToggle) {
                mobileMenuToggle.addEventListener("click", () => {
                    mobileMenuToggle.classList.toggle("active");
                    navLinks.classList.toggle("active");
                });

                // Close menu when clicking on a link
                const links = navLinks.querySelectorAll("a");
                links.forEach((link) => {
                    link.addEventListener("click", () => {
                        mobileMenuToggle.classList.remove("active");
                        navLinks.classList.remove("active");
                    });
                });
            }

            // Dropdown navigation
            const dropdownToggle = document.querySelector(
                ".nav-dropdown-toggle",
            );
            const dropdownMenu = document.querySelector(".nav-dropdown-menu");
            const navDropdown = document.querySelector(".nav-dropdown");

            if (dropdownToggle && dropdownMenu) {
                dropdownToggle.addEventListener("click", (e) => {
                    e.stopPropagation();
                    navDropdown.classList.toggle("active");
                });

                // Close dropdown when clicking outside
                document.addEventListener("click", () => {
                    navDropdown.classList.remove("active");
                });

                navDropdown.addEventListener("click", (e) => {
                    e.stopPropagation();
                });
            }

            // Accordion: single-open. Animation is pure CSS (grid-template-rows
            // on the body), so JS only toggles a class — no height measurement.
            const areaBlocks = document.querySelectorAll(".area-block");

            function toggleBlock(block) {
                const willOpen = !block.classList.contains("is-open");
                // single-open: close every block first, then open the clicked one
                areaBlocks.forEach((b) => {
                    b.classList.remove("is-open");
                    const t = b.querySelector(".area-block-summary");
                    if (t) t.setAttribute("aria-expanded", "false");
                });
                if (willOpen) {
                    block.classList.add("is-open");
                    const t = block.querySelector(".area-block-summary");
                    if (t) t.setAttribute("aria-expanded", "true");
                }
            }

            areaBlocks.forEach((block) => {
                const trigger = block.querySelector(".area-block-summary");
                if (!trigger) return;
                trigger.addEventListener("click", () => toggleBlock(block));
                trigger.addEventListener("keydown", (e) => {
                    if (e.key === "Enter" || e.key === " " || e.key === "Spacebar") {
                        e.preventDefault();
                        toggleBlock(block);
                    }
                });
            });

            // Deep links dos cartões da homepage (/pt/servicos#stock): chegar
            // com essa área já aberta, não num acordeão fechado.
            function openFromHash() {
                const id = window.location.hash.slice(1);
                if (!id) return;
                const target = document.getElementById(id);
                if (!target || !target.classList.contains("area-block")) return;
                if (!target.classList.contains("is-open")) toggleBlock(target);
                // "start" + scroll-margin-top deixa o título logo abaixo da nav,
                // e coincide com o sítio onde o salto nativo do browser aterra,
                // por isso não há correção visível seja qual for o que corre por último.
                requestAnimationFrame(() => {
                    target.scrollIntoView({ behavior: "smooth", block: "start" });
                });
            }
            openFromHash();
            window.addEventListener("hashchange", openFromHash);

            // Scroll reveal (shared .reveal / .in-view utility from tokens.css)
            const revealEls = document.querySelectorAll(".reveal");
            if (revealEls.length && "IntersectionObserver" in window) {
                const revealIO = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) {
                                entry.target.classList.add("in-view");
                                revealIO.unobserve(entry.target);
                            }
                        });
                    },
                    { threshold: 0.12, rootMargin: "0px 0px -8% 0px" },
                );
                revealEls.forEach((el) => revealIO.observe(el));
            } else {
                revealEls.forEach((el) => el.classList.add("in-view"));
            }
        </script>

        <Footer locale="pt" />
    </body>
</html>

<style>
    /* Reset & Base Styles */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    /* design tokens loaded from tokens.css */

    body {
        font-family: var(--font-primary);
        background-color: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        overflow-x: hidden;
    }

    /* Navigation */
    .navigation {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 60px;
        position: sticky;
        top: 0;
        background-color: var(--color-bg);
        z-index: 1000;
        transition: transform 0.3s ease;
    }

    .logo {
        font-family: var(--font-heading);
        font-size: 32px;
        letter-spacing: -0.32px;
        color: var(--color-text);
    }

    .nav-links {
        display: flex;
        gap: 32px;
        align-items: center;
    }

    .nav-links a {
        color: var(--color-text);
        text-decoration: none;
        font-size: 16px;
        font-weight: 500;
        letter-spacing: -0.48px;
        transition: color 0.3s ease;
